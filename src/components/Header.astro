---
const navItems = [
  { label: 'Crops', href: '/crops/' },
  { label: 'ROI', href: '/roi/' },
  { label: 'Homestead', href: '/homestead/' },
  { label: 'Guides', href: '/guides/' },
  { label: 'Resources', href: '/resources/' },
];

const currentPath = Astro.url.pathname;
---

<header class="site-header">
  <div class="container header-inner">
    <a href="/" class="logo" aria-label="Garden ROI Home">
      <img src="/logo.png" alt="Garden ROI" width="40" height="40" loading="eager" />
      <span class="logo-block">
        <span class="logo-title-row">
          <span class="logo-text">Garden ROI</span>
          <span class="logo-beta">beta</span>
        </span>
        <span class="logo-tagline">by the Herb Guy</span>
      </span>
    </a>

    <nav class="main-nav" aria-label="Main navigation">
      <ul>
        {navItems.map((item) => (
          <li>
            <a
              href={item.href}
              class:list={['nav-link', { active: currentPath.startsWith(item.href) }]}
            >
              {item.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <a href="/app/" class="btn btn-primary btn-sm header-cta">
      Get the App
    </a>

    <button class="mobile-menu-btn" aria-label="Toggle menu" id="menu-toggle">
      <span></span><span></span><span></span>
    </button>
  </div>

  <!-- Mobile nav -->
  <div class="mobile-nav" id="mobile-nav">
    <ul>
      {navItems.map((item) => (
        <li>
          <a href={item.href} class="mobile-nav-link">{item.label}</a>
        </li>
      ))}
      <li>
        <a href="/#download" class="btn btn-primary mobile-cta-full">Get the App</a>
      </li>
    </ul>
  </div>
</header>

<script>
  const toggle = document.getElementById('menu-toggle');
  const nav = document.getElementById('mobile-nav');
  toggle?.addEventListener('click', () => {
    nav?.classList.toggle('open');
  });
</script>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background-color: var(--color-tab-bar-translucent);
    backdrop-filter: blur(8px);
    border-bottom: 1px solid rgba(255, 255, 255, 0.12);
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.3);
  }

  .header-inner {
    display: flex;
    align-items: center;
    gap: var(--space-l);
    height: var(--header-height);
  }

  .logo {
    display: flex;
    align-items: center;
    gap: var(--space-s);
    text-decoration: none;
    flex-shrink: 0;
  }

  .logo img {
    width: 40px;
    height: 40px;
    object-fit: contain;
  }

  .logo-block {
    display: flex;
    flex-direction: column;
    gap: 1px;
  }

  .logo-title-row {
    display: flex;
    align-items: flex-start;
    gap: 5px;
  }

  .logo-text {
    font-family: var(--font-display);
    font-size: var(--text-logo);
    color: var(--color-tab-active);
    line-height: 1;
  }

  .logo-beta {
    font-family: var(--font-body);
    font-size: var(--text-micro);
    font-weight: 600;
    color: var(--color-white);
    background-color: var(--color-primary-light);
    padding: 1px 5px;
    border-radius: 4px;
    margin-top: 1px;
    line-height: 1.4;
  }

  .logo-tagline {
    font-family: var(--font-body);
    font-size: var(--text-badge);
    font-style: italic;
    color: var(--color-tab-inactive);
    line-height: 1;
    margin-left: 2px;
  }

  .main-nav {
    flex: 1;
  }

  .main-nav ul {
    display: flex;
    gap: var(--space-l);
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .nav-link {
    font-size: var(--text-body);
    font-weight: 600;
    color: var(--color-tab-inactive);
    text-decoration: none;
    padding: var(--space-xs) 0;
    border-bottom: 2px solid transparent;
    transition: color 0.2s, border-color 0.2s;
  }

  .nav-link:hover,
  .nav-link.active {
    color: var(--color-tab-active);
    border-bottom-color: var(--color-tab-active);
  }

  .btn-sm {
    padding: var(--space-btn-y) var(--space-m);
    font-size: var(--text-small);
  }

  .mobile-menu-btn {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: var(--space-s);
  }

  .mobile-menu-btn span {
    display: block;
    width: 24px;
    height: 2px;
    background-color: var(--color-tab-inactive);
    border-radius: 2px;
  }

  .mobile-nav {
    display: none;
    background-color: var(--color-tab-bar-translucent);
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    padding: var(--space-m);
  }

  .mobile-nav.open {
    display: block;
  }

  .mobile-nav ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-m);
  }

  .mobile-cta-full {
    width: 100%;
    justify-content: center;
  }

  .mobile-nav-link {
    font-size: var(--text-body);
    font-weight: 600;
    color: var(--color-tab-inactive);
    text-decoration: none;
  }

  @media (max-width: 768px) {
    .main-nav,
    .header-cta {
      display: none;
    }

    .mobile-menu-btn {
      display: flex;
      margin-left: auto;
    }
  }
</style>
