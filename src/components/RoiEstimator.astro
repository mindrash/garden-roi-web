---
import { getCollection } from 'astro:content';

const allPlants = await getCollection('plants');
const plants = allPlants
  .sort((a, b) => a.data.name.localeCompare(b.data.name))
  .map((p) => ({
    name: p.data.name,
    slug: p.id,
    avg_yield_lb: p.data.avg_yield_lb,
    avg_price_lb: p.data.avg_price_lb,
    seed_cost: p.data.seed_cost,
  }));

const plantsJson = JSON.stringify(plants);
---

<div class="estimator">
  <!-- Baked-in plant data — read by the script below -->
  <script id="estimator-data" type="application/json" set:html={plantsJson}></script>

  <!-- Inputs: single row across the top -->
  <div class="estimator-inputs">
    <div class="input-group input-group-crop">
      <label for="est-crop" class="input-label">Crop</label>
      <select id="est-crop" class="est-select">
        <option value="">— Select a crop —</option>
        {plants.map((p) => (
          <option value={p.slug}>{p.name}</option>
        ))}
      </select>
    </div>

    <div class="input-group input-group-count">
      <label for="est-plants" class="input-label">Plants</label>
      <input
        type="number"
        id="est-plants"
        class="est-number"
        min="1"
        max="50"
        value="3"
      />
    </div>
  </div>

  <!-- Output: full width below inputs, hidden until crop selected -->
  <div class="estimator-output" id="est-output">
    <div class="est-result" id="est-result" hidden>
      <div class="est-stats">
        <div class="est-net-savings">
          <span class="est-net-label">Net savings</span>
          <span class="est-net-value" id="est-net-value">$0.00</span>
        </div>
        <div class="est-breakdown">
          <div class="est-row">
            <span class="est-row-label">Estimated yield</span>
            <span class="est-row-value" id="est-yield-val">—</span>
          </div>
          <div class="est-row">
            <span class="est-row-label">Grocery value</span>
            <span class="est-row-value" id="est-grocery-val">—</span>
          </div>
          <div class="est-row est-row-deduct">
            <span class="est-row-label">Seed investment</span>
            <span class="est-row-value" id="est-seed-val">—</span>
          </div>
        </div>
      </div>

      <div class="est-footer">
        <p class="est-source">Based on USDA average yield and retail price data.</p>
        <a href="/app/" class="btn btn-primary est-cta">Track your actual harvest →</a>
      </div>
    </div>
  </div>
</div>

<script>
  interface PlantData {
    name: string;
    slug: string;
    avg_yield_lb: number;
    avg_price_lb: number;
    seed_cost: number;
  }

  const raw = document.getElementById('estimator-data')?.textContent ?? '[]';
  const plants: PlantData[] = JSON.parse(raw);
  const plantMap = new Map(plants.map((p) => [p.slug, p]));

  const cropSelect  = document.getElementById('est-crop')    as HTMLSelectElement | null;
  const plantInput  = document.getElementById('est-plants')  as HTMLInputElement  | null;
  const result      = document.getElementById('est-result')  as HTMLElement       | null;
  const netValue    = document.getElementById('est-net-value')   as HTMLElement   | null;
  const yieldVal    = document.getElementById('est-yield-val')   as HTMLElement   | null;
  const groceryVal  = document.getElementById('est-grocery-val') as HTMLElement   | null;
  const seedVal     = document.getElementById('est-seed-val')    as HTMLElement   | null;

  function fmt(n: number): string {
    return '$' + n.toFixed(2);
  }

  function recalc() {
    const slug   = cropSelect?.value ?? '';
    const count  = Math.min(50, Math.max(1, parseInt(plantInput?.value ?? '3', 10) || 1));
    const plant  = plantMap.get(slug);

    if (!plant) {
      if (result) result.hidden = true;
      return;
    }

    const yield_lb     = plant.avg_yield_lb * count;
    const grocery      = yield_lb * plant.avg_price_lb;
    const seed         = plant.seed_cost * count;
    const net          = grocery - seed;

    if (result) result.hidden = false;

    if (netValue)   netValue.textContent  = fmt(net);
    if (yieldVal)   yieldVal.textContent  = yield_lb.toFixed(1) + ' lb';
    if (groceryVal) groceryVal.textContent = fmt(grocery);
    if (seedVal)    seedVal.textContent   = fmt(seed);
  }

  cropSelect?.addEventListener('change', recalc);
  plantInput?.addEventListener('input',  recalc);
</script>

<style>
  .estimator {
    display: flex;
    flex-direction: column;
    gap: var(--space-l);
  }

  /* Inputs row */
  .estimator-inputs {
    display: flex;
    gap: var(--space-m);
    align-items: end;
  }

  .input-group-crop {
    flex: 1;
  }

  .input-group-count {
    flex: 0 0 100px;
  }

  .input-group {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .input-label {
    font-size: var(--text-small);
    font-weight: 700;
    color: var(--color-text-secondary);
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .est-select,
  .est-number {
    padding: var(--space-s) var(--space-m);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-m);
    font-family: var(--font-body);
    font-size: var(--text-body);
    color: var(--color-text-primary);
    background-color: var(--color-white);
    width: 100%;
    outline: none;
    transition: border-color 0.15s;
  }

  .est-select:focus,
  .est-number:focus {
    border-color: var(--color-primary);
    box-shadow: 0 0 0 2px var(--color-highlight);
  }

  /* Output */
  .estimator-output {
    display: flex;
    flex-direction: column;
  }

  .est-result {
    display: flex;
    flex-direction: column;
    gap: var(--space-l);
  }

  /* Stats row: green net savings box + breakdown side by side */
  .est-stats {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: var(--space-l);
    align-items: center;
  }

  .est-net-savings {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-xs);
    padding: var(--space-l) var(--space-xl);
    background: linear-gradient(135deg, var(--color-primary-dark), var(--color-primary));
    border-radius: var(--radius-m);
    text-align: center;
    white-space: nowrap;
  }

  .est-net-label {
    font-size: var(--text-small);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: rgba(255, 255, 255, 0.75);
  }

  .est-net-value {
    font-family: var(--font-display);
    font-size: var(--text-stat);
    line-height: var(--leading-stat);
    color: var(--color-tab-active);
  }

  /* Breakdown rows */
  .est-breakdown {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .est-row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding: var(--space-xs) 0;
    border-bottom: 1px solid rgba(0, 0, 0, 0.06);
    font-size: var(--text-small);
  }

  .est-row:last-child {
    border-bottom: none;
  }

  .est-row-label {
    color: var(--color-text-muted);
  }

  .est-row-value {
    font-weight: 700;
    color: var(--color-text-primary);
  }

  .est-row-deduct .est-row-value {
    color: var(--color-error);
  }

  /* Footer: source note + CTA */
  .est-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-m);
  }

  .est-source {
    font-size: var(--text-small);
    color: var(--color-text-muted);
    margin: 0;
  }

  .est-cta {
    flex-shrink: 0;
    white-space: nowrap;
  }

  @media (max-width: 600px) {
    .est-stats {
      grid-template-columns: 1fr;
    }

    .est-net-savings {
      white-space: normal;
    }

    .est-footer {
      flex-direction: column;
      align-items: flex-start;
    }

    .est-cta {
      width: 100%;
      justify-content: center;
    }
  }
</style>
