---

<div class="app-badges" id="download">
  <a
    href="https://apps.apple.com/us/app/garden-roi/id6760734178"
    target="_blank"
    rel="noopener noreferrer"
    class="badge-link"
    aria-label="Download Garden ROI on the App Store"
  >
    <img
      src="/badges/apple-app-store.svg"
      alt="Download on the App Store"
      width="156"
      height="52"
      loading="lazy"
    />
  </a>
  <a
    href="https://play.google.com/store/apps/details?id=com.fleeflame.gardenroi"
    target="_blank"
    rel="noopener noreferrer"
    class="badge-link"
    aria-label="Get Garden ROI on Google Play"
  >
    <img
      src="/badges/google-play.svg"
      alt="Get it on Google Play"
      width="175"
      height="52"
      loading="lazy"
    />
  </a>
</div>

<style>
  .app-badges {
    display: flex;
    align-items: center;
    gap: var(--space-m);
    flex-wrap: nowrap;
  }

  .badge-link {
    display: block;
    flex-shrink: 1;
    transition: opacity 0.2s, transform 0.1s;
  }

  .badge-link:hover {
    opacity: 0.85;
    transform: translateY(-2px);
    text-decoration: none;
  }

  .badge-link img {
    height: 52px;
    width: auto;
    max-width: 100%;
  }

  @media (max-width: 400px) {
    .badge-link img {
      height: 42px;
    }
  }
</style>
