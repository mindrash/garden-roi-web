---
---
<div class="roi-calculator" id="roi-calc">
  <p class="calc-intro">Pick a crop and plant count to see the return on investment for that bed at grocery store prices.</p>
  <div class="calc-inputs">
    <div class="calc-field">
      <label for="crop-select">Crop</label>
      <select id="crop-select" name="crop">
        <option value="">Loading crops...</option>
      </select>
    </div>
    <div class="calc-field">
      <label for="plant-count">Number of plants</label>
      <input type="number" id="plant-count" name="plant-count" min="1" max="50" value="4" />
    </div>
  </div>
  <div class="calc-result" id="calc-result" aria-live="polite">
    <span class="result-label">Estimated grocery value at harvest</span>
    <span class="result-value" id="result-value">--</span>
  </div>
  <p class="calc-note">
    This is gross value based on average retail prices. Subtract your seed cost for net ROI. Track actual harvests in the <a href="/app/">Garden ROI app</a> to see real return vs. estimates.
  </p>
</div>

<script>
  interface PlantData {
    name: string;
    slug: string;
    avg_yield_lb: number;
    avg_price_lb: number;
  }

  let plants: PlantData[] = [];

  async function loadPlants() {
    try {
      const res = await fetch('/api/plants.json');
      const data = await res.json();
      plants = data.plants as PlantData[];
      const select = document.getElementById('crop-select') as HTMLSelectElement;
      select.innerHTML = plants
        .map((p) => `<option value="${p.slug}" data-yield="${p.avg_yield_lb}" data-price="${p.avg_price_lb}">${p.name}</option>`)
        .join('');
      updateResult();
    } catch {
      const select = document.getElementById('crop-select') as HTMLSelectElement;
      select.innerHTML = '<option value="">Unable to load crops</option>';
    }
  }

  function updateResult() {
    const select = document.getElementById('crop-select') as HTMLSelectElement;
    const countInput = document.getElementById('plant-count') as HTMLInputElement;
    const resultEl = document.getElementById('result-value') as HTMLElement;

    const selected = select.options[select.selectedIndex];
    if (!selected || !selected.dataset.yield) {
      resultEl.textContent = '--';
      return;
    }

    const yieldLb = parseFloat(selected.dataset.yield ?? '0');
    const price = parseFloat(selected.dataset.price ?? '0');
    const count = Math.max(1, parseInt(countInput.value, 10) || 1);
    const savings = (yieldLb * price * count).toFixed(2);
    resultEl.textContent = `$${savings}`;
  }

  document.getElementById('crop-select')?.addEventListener('change', updateResult);
  document.getElementById('plant-count')?.addEventListener('input', updateResult);

  loadPlants();
</script>

<style>
  .roi-calculator {
    display: flex;
    flex-direction: column;
    gap: var(--space-m);
    max-width: var(--content-width);
  }

  .roi-calculator h3 {
    font-size: var(--text-h3);
    color: var(--color-primary);
    margin: 0;
  }

  .calc-intro {
    font-size: var(--text-body);
    color: var(--color-text-secondary);
    margin: 0;
    line-height: var(--leading-body);
  }

  .calc-inputs {
    display: flex;
    gap: var(--space-l);
    flex-wrap: wrap;
  }

  .calc-field {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
    flex: 1;
    min-width: 160px;
  }

  .calc-field label {
    font-size: var(--text-small);
    font-weight: 600;
    color: var(--color-text-secondary);
  }

  .calc-field select,
  .calc-field input {
    padding: var(--space-s) var(--space-m);
    border-radius: var(--radius-s);
    border: 1px solid rgba(0, 0, 0, 0.15);
    font-family: var(--font-body);
    font-size: var(--text-body);
    color: var(--color-text-primary);
    background-color: var(--color-bg);
    width: 100%;
  }

  .calc-result {
    display: flex;
    align-items: center;
    justify-content: space-between;
    background-color: var(--color-highlight);
    border-radius: var(--radius-s);
    padding: var(--space-m) var(--space-l);
    gap: var(--space-m);
  }

  .result-label {
    font-size: var(--text-body);
    color: var(--color-text-secondary);
    font-weight: 600;
  }

  .result-value {
    font-size: var(--text-h2);
    font-weight: 700;
    color: var(--color-primary);
    font-family: var(--font-body);
  }

  .calc-note {
    font-size: var(--text-small);
    color: var(--color-text-muted);
    margin: 0;
  }

  .calc-note a {
    color: var(--color-primary);
    font-weight: 600;
  }
</style>
