---
import '../styles/theme.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const {
  title,
  description = 'Plant care tips, homestead advice, and ROI guides to help your garden pay for itself.',
  ogImage = '/bg-1.webp',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="canonical" href={canonicalURL} />

    <!-- Google Fonts: Inter + Piedra -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&family=Piedra&display=swap"
      rel="stylesheet"
    />

    <title>{title} | Garden ROI</title>
    <meta name="description" content={description} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={`${title} | Garden ROI`} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, Astro.site)} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={`${title} | Garden ROI`} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, Astro.site)} />

    <!-- Structured Data: Organization -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "Garden ROI",
      "url": "https://gardenroi.com",
      "logo": "https://gardenroi.com/logo.png",
      "sameAs": [
        "https://apps.apple.com/us/app/garden-roi/id6760734178",
        "https://play.google.com/store/apps/details?id=com.fleeflame.gardenroi"
      ]
    })} />
  </head>
  <body>
    <div class="site-bg" aria-hidden="true"></div>
    <a href="#main-content" class="skip-to-content">Skip to main content</a>
    <Header />
    <main id="main-content">
      <slot />
    </main>
    <Footer />
    <script is:inline src="/insects.js"></script>
  </body>
</html>
