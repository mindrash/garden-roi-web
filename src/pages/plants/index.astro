---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PlantCard from '../../components/PlantCard.astro';
import { getCollection } from 'astro:content';

const allPlants = await getCollection('plants');

// Sort: common first, then alphabetical
const plants = allPlants.sort((a, b) => {
  if (a.data.is_common !== b.data.is_common) return a.data.is_common ? -1 : 1;
  return a.data.name.localeCompare(b.data.name);
});

const categories = ['All', 'Vegetable', 'Herb', 'Fruit'] as const;
---

<BaseLayout
  title="Plant Encyclopedia"
  description="Care guides, ROI breakdowns, and growing tips for vegetables, herbs, and fruit. Find your next high-value crop."
>
  <div class="page-header">
    <div class="container">
      <h1>Plant Encyclopedia</h1>
      <p>Care guides and ROI breakdowns for the most productive home garden crops.</p>
    </div>
  </div>

  <div class="container plants-page">
    <!-- Category filter (CSS-only) -->
    <div class="filter-bar" role="tablist" aria-label="Filter by category">
      {categories.map((cat) => (
        <a
          href={cat === 'All' ? '/plants/' : `/plants/?category=${cat}`}
          class="filter-btn"
          data-category={cat}
        >
          {cat}
        </a>
      ))}
    </div>

    <div class="plants-grid" id="plants-grid">
      {plants.map((plant) => (
        <div data-category={plant.data.category} class="plant-item">
          <PlantCard
            slug={plant.id}
            name={plant.data.name}
            scientific_name={plant.data.scientific_name}
            category={plant.data.category}
            days_min={plant.data.days_min}
            days_max={plant.data.days_max}
            avg_yield_lb={plant.data.avg_yield_lb}
            avg_price_lb={plant.data.avg_price_lb}
            watering={plant.data.watering}
            sunlight={plant.data.sunlight}
          />
        </div>
      ))}
    </div>
  </div>
</BaseLayout>

<script>
  // Client-side category filtering
  const params = new URLSearchParams(window.location.search);
  const active = params.get('category') || 'All';

  // Highlight active filter
  document.querySelectorAll<HTMLElement>('.filter-btn').forEach((btn) => {
    if (btn.dataset.category === active) {
      btn.classList.add('active');
    }
  });

  // Filter plant items
  if (active !== 'All') {
    document.querySelectorAll<HTMLElement>('.plant-item').forEach((item) => {
      if (item.dataset.category !== active) {
        item.style.display = 'none';
      }
    });
  }
</script>

<style>
  .page-header {
    background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-light) 100%);
    padding: var(--space-xxl) 0 var(--space-xl);
  }

  .page-header h1 {
    font-family: var(--font-display);
    color: var(--color-white);
    font-size: var(--text-screen-title);
    margin-bottom: var(--space-s);
  }

  .page-header p {
    color: rgba(255,255,255,0.85);
    font-size: var(--text-body);
    margin: 0;
  }

  .plants-page {
    padding: var(--space-xl) var(--space-l);
  }

  .filter-bar {
    display: flex;
    gap: var(--space-s);
    margin-bottom: var(--space-xl);
    flex-wrap: wrap;
  }

  .filter-btn {
    padding: var(--space-xs) var(--space-m);
    border-radius: var(--radius-full);
    border: 2px solid var(--color-primary);
    color: var(--color-primary);
    font-size: var(--text-small);
    font-weight: 600;
    text-decoration: none;
    transition: background-color 0.2s, color 0.2s;
    background: transparent;
  }

  .filter-btn:hover,
  .filter-btn.active {
    background-color: var(--color-primary);
    color: var(--color-white);
    text-decoration: none;
  }

  .plants-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-l);
  }

  @media (max-width: 900px) {
    .plants-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 600px) {
    .plants-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
