---
import ArticleLayout from '../../layouts/ArticleLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const articles = await getCollection('articles');
  return articles
    .filter((a) => a.data.category === 'homestead')
    .map((article) => ({
      params: { slug: article.id },
      props: { article },
    }));
}

const { article } = Astro.props;
---

<ArticleLayout
  article={article}
  categoryTag="tag-homestead"
  categoryLabel="Homestead"
  backHref="/homestead/"
  backLabel="← All Homestead Articles"
  breadcrumbLabel="Homestead"
  breadcrumbHref="/homestead/"
/>
