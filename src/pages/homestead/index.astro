---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import { getCollection } from 'astro:content';

const allArticles = await getCollection('articles');
const articles = allArticles
  .filter((a) => a.data.category === 'homestead')
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime());
---

<BaseLayout
  title="Homestead Skills That Multiply Your Garden's Value"
  description="Preservation, storage, seed saving, and soil systems  -  the post-harvest skills that turn a garden harvest into year-round food cost savings."
>
  <div class="page-header">
    <div class="container">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <ol>
          <li><a href="/">Home</a></li>
          <li aria-current="page">Homestead</li>
        </ol>
      </nav>
      <h1>Homestead</h1>
      <p>What you do after harvest multiplies the financial value of what you grow.</p>
    </div>
  </div>

  <div class="container section-page">
    {articles.length === 0 ? (
      <p class="empty">Articles coming soon.</p>
    ) : (
      <div class="articles-grid">
        {articles.map((article) => (
          <ArticleCard
            slug={article.id}
            title={article.data.title}
            description={article.data.description}
            category={article.data.category}
            publishDate={article.data.publishDate}
            featured={article.data.featured}
            sectionPath="/homestead"
          />
        ))}
      </div>
    )}
  </div>
</BaseLayout>

<style>
  .breadcrumb ol {
    display: flex;
    gap: var(--space-xs);
    list-style: none;
    padding: 0;
    margin: 0 0 var(--space-m);
    font-size: var(--text-small);
  }

  .breadcrumb li {
    display: flex;
    align-items: center;
    gap: var(--space-xs);
    color: rgba(255, 255, 255, 0.7);
  }

  .breadcrumb li:not(:last-child)::after {
    content: '/';
    color: rgba(255, 255, 255, 0.4);
  }

  .breadcrumb a {
    color: rgba(255, 255, 255, 0.85);
    text-decoration: none;
  }

  .breadcrumb a:hover {
    color: var(--color-white);
    text-decoration: underline;
  }

  .section-page {
    padding: var(--space-xl) var(--space-l);
  }

  .articles-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-l);
  }

  .empty {
    color: var(--color-text-muted);
    font-size: var(--text-body);
    padding: var(--space-xl) 0;
  }

  @media (max-width: 900px) {
    .articles-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 600px) {
    .articles-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
