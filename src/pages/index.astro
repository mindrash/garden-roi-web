---
import BaseLayout from '../layouts/BaseLayout.astro';
import AppStoreBadges from '../components/AppStoreBadges.astro';
import PlantCard from '../components/PlantCard.astro';
import ArticleCard from '../components/ArticleCard.astro';
import RoiCalculator from '../components/RoiCalculator.astro';
import RoiEstimator from '../components/RoiEstimator.astro';
import GardenFact from '../components/GardenFact.astro';
import { getCollection } from 'astro:content';

const allPlants = await getCollection('plants');
const allArticles = await getCollection('articles');

// Highest-ROI crop for section anchor
const topCrop = allPlants
  .sort((a, b) => {
    const roiA = (a.data.avg_yield_lb * a.data.avg_price_lb) / a.data.seed_cost;
    const roiB = (b.data.avg_yield_lb * b.data.avg_price_lb) / b.data.seed_cost;
    return roiB - roiA;
  })[0];

// Featured ROI article
const roiArticle = allArticles
  .filter((a) => a.data.category === 'roi')
  .sort((a, b) => (b.data.featured ? 1 : 0) - (a.data.featured ? 1 : 0))[0];

// Featured homestead article
const homesteadArticle = allArticles
  .filter((a) => a.data.category === 'homestead')
  .sort((a, b) => (b.data.featured ? 1 : 0) - (a.data.featured ? 1 : 0))[0];

// Show common plants  -  ROI sorted
const featuredPlants = allPlants
  .filter((p) => p.data.is_common)
  .sort((a, b) => {
    const roiA = (a.data.avg_yield_lb * a.data.avg_price_lb) / a.data.seed_cost;
    const roiB = (b.data.avg_yield_lb * b.data.avg_price_lb) / b.data.seed_cost;
    return roiB - roiA;
  })
  .slice(0, 3);

// Featured articles  -  with proper section routing
const featuredArticles = allArticles
  .filter((a) => a.data.featured)
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime())
  .slice(0, 3);

function sectionPathFor(category: string): string {
  if (category === 'roi') return '/roi';
  if (category === 'homestead') return '/homestead';
  return '/guides';
}

const topCropRoi = topCrop
  ? ((topCrop.data.avg_yield_lb * topCrop.data.avg_price_lb) / topCrop.data.seed_cost).toFixed(0)
  : '0';
---

<BaseLayout
  title="Grow More, Spend Less"
  description="Plant care tips, homestead guides, and ROI advice to help your garden pay for itself. Companion to the Garden ROI app."
>
  <!-- Hero -->
  <section class="hero">
    <div class="hero-bg">
      <div class="hero-overlay"></div>
    </div>
    <div class="container hero-content">
      <div class="hero-text">
        <h1>{topCrop ? `${topCrop.data.name} returns ${topCropRoi}× seed cost.` : 'Your garden should pay you back.'}<br />Here's how to make that happen.</h1>
        <p class="hero-subtitle">
          Crop ROI breakdowns, homestead skills, and financial guides to help your garden pay for itself  -  season after season.
        </p>
        <div class="hero-actions">
          <a href="/crops/" class="btn btn-primary">Browse Crops</a>
          <a href="/start-here/" class="btn btn-outline-light">New? Start Here</a>
        </div>
      </div>
      <div class="hero-app">
        <div class="app-card">
          <div class="app-card-header">
            <img src="/logo.png" alt="Garden ROI App" width="64" height="64" loading="eager" class="app-icon" />
            <h3>Track Your Garden's Return on Investment, Down to the Last Harvest.</h3>
          </div>
          <p>Log harvests, track expenses, and see exactly when your garden breaks even  -  right in the app.</p>
          <ul class="app-features">
            <li>Know your break-even date before the season ends</li>
            <li>See which crops earn the most per square foot</li>
            <li>Compare varieties by real yield, not seed-packet promises</li>
          </ul>
          <AppStoreBadges />
          <div id="nl-section">
            <hr class="nl-divider" />
            <div id="nl-form-state">
              <p class="nl-label">Get planting tips and ROI data in your inbox</p>
              <div class="nl-row">
                <input
                  type="email"
                  id="nl-email"
                  class="nl-input"
                  placeholder="you@example.com"
                  autocomplete="email"
                />
                <button type="button" id="nl-submit" class="btn btn-primary nl-btn">Subscribe</button>
              </div>
              <p class="nl-error" id="nl-error" aria-live="polite"></p>
            </div>
            <div id="nl-success-state" hidden>
              <p class="nl-label nl-subscribed">&#10003; You're subscribed.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Section anchors -->
  <section class="section-anchors">
    <div class="container anchors-grid">
      <!-- Crops anchor -->
      <div class="anchor-card">
        <div class="anchor-label">Crops</div>
        {topCrop && (
          <a href={`/crops/${topCrop.id}/`} class="anchor-title">{topCrop.data.name}</a>
        )}
        {topCrop && (
          <p class="anchor-desc">
            Yields ~{topCrop.data.avg_yield_lb} lb at ${topCrop.data.avg_price_lb}/lb grocery value. Full ROI breakdown and growing guide.
          </p>
        )}
        <a href="/crops/" class="anchor-link">All crops →</a>
      </div>

      <!-- ROI anchor -->
      <div class="anchor-card anchor-card-roi">
        <div class="anchor-label">ROI</div>
        {roiArticle && (
          <a href={`/roi/${roiArticle.id}/`} class="anchor-title">{roiArticle.data.title}</a>
        )}
        {roiArticle && (
          <p class="anchor-desc">{roiArticle.data.description}</p>
        )}
        <a href="/roi/" class="anchor-link">All ROI articles →</a>
      </div>

      <!-- Homestead anchor -->
      <div class="anchor-card anchor-card-homestead">
        <div class="anchor-label">Homestead</div>
        {homesteadArticle && (
          <a href={`/homestead/${homesteadArticle.id}/`} class="anchor-title">{homesteadArticle.data.title}</a>
        )}
        {homesteadArticle && (
          <p class="anchor-desc">{homesteadArticle.data.description}</p>
        )}
        <a href="/homestead/" class="anchor-link">All homestead articles →</a>
      </div>
    </div>
  </section>

  <!-- ROI Calculator -->
  <section class="section section-card">
    <div class="container">
      <div class="glass-card">
        <div class="section-header section-header-tight">
          <h2 class="section-title">Garden Return on Investment Calculator</h2>
        </div>
        <RoiCalculator />
      </div>
    </div>
  </section>

  <!-- Featured Plants -->
  <section class="section section-card">
    <div class="container">
      <div class="glass-card">
        <div class="section-header section-header-tight">
          <h2 class="section-title">Plant Encyclopedia</h2>
          <a href="/crops/" class="section-link">View all crops →</a>
        </div>
        <div class="card-grid">
          {featuredPlants.map((plant) => (
            <PlantCard
            slug={plant.id}
            name={plant.data.name}
            scientific_name={plant.data.scientific_name}
            category={plant.data.category}
            days_min={plant.data.days_min}
            days_max={plant.data.days_max}
            avg_yield_lb={plant.data.avg_yield_lb}
            avg_price_lb={plant.data.avg_price_lb}
            watering={plant.data.watering}
            sunlight={plant.data.sunlight}
          />
        ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Garden Fact -->
  <section class="section-fact">
    <div class="container">
      <GardenFact />
    </div>
  </section>

  <!-- Featured Articles -->
  <section class="section section-alt">
    <div class="container">
      <div class="section-header">
        <h2 class="section-title">Latest Articles</h2>
        <a href="/guides/" class="section-link">View all guides →</a>
      </div>
      <div class="card-grid">
        {featuredArticles.map((article) => (
          <ArticleCard
            slug={article.id}
            title={article.data.title}
            description={article.data.description}
            category={article.data.category}
            publishDate={article.data.publishDate}
            featured={article.data.featured}
            sectionPath={sectionPathFor(article.data.category)}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- ROI Estimator -->
  <section class="section section-card">
    <div class="container">
      <div class="glass-card">
        <div class="section-header section-header-tight">
          <h2 class="section-title">Estimate Your Return</h2>
        </div>
        <RoiEstimator />
      </div>
    </div>
  </section>

  <!-- App CTA -->
  <section class="app-cta" id="download">
    <div class="container app-cta-inner">
      <div class="app-cta-text">
        <h2>Track Your Garden's Return on Investment</h2>
        <p>Log every harvest, every expense. Know your break-even date. See which plants are your biggest earners. Available free on iOS and Android.</p>
        <div class="app-cta-actions">
          <AppStoreBadges />
          <a href="/app/" class="btn app-learn-more">Learn more →</a>
        </div>
      </div>
      <div class="app-cta-visual">
        <img src="/logo.png" alt="Garden ROI app icon" width="200" height="200" loading="lazy" />
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    position: relative;
    overflow: hidden;
    min-height: 520px;
    display: flex;
    align-items: center;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(0, 0, 0, 0.25) 0%,
      rgba(45, 90, 39, 0.55) 100%
    );
  }

  .hero-content {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-xxl);
    align-items: center;
    padding-top: var(--space-xxl);
    padding-bottom: var(--space-xxl);
  }

  .hero-text h1 {
    font-family: var(--font-display);
    font-size: clamp(40px, 6vw, 64px);
    line-height: 1.1;
    color: var(--color-tab-active);
    -webkit-text-stroke: 2px var(--color-tab-bar);
    paint-order: stroke fill;
    text-shadow: 0 3px 16px rgba(0,0,0,0.4);
    margin-bottom: var(--space-m);
  }

  .hero-subtitle {
    font-size: clamp(var(--text-body), 2vw, 20px);
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.92);
    margin-bottom: var(--space-xl);
    text-shadow: 0 1px 4px rgba(0,0,0,0.2);
    max-width: 480px;
  }

  .hero-actions {
    display: flex;
    gap: var(--space-m);
    flex-wrap: wrap;
  }

  .app-card {
    background: rgba(255, 255, 255, 0.98);
    backdrop-filter: blur(10px);
    border-radius: var(--radius-l);
    padding: var(--space-xl);
    box-shadow: var(--shadow-card);
    display: flex;
    flex-direction: column;
    gap: var(--space-m);
    align-items: flex-start;
  }

  .app-card-header {
    display: flex;
    align-items: center;
    gap: var(--space-m);
  }

  .app-icon {
    border-radius: var(--radius-m);
    flex-shrink: 0;
  }

  .app-features {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .app-features li {
    font-size: var(--text-small);
    color: var(--color-text-secondary);
    line-height: var(--leading-small);
    padding-left: var(--space-m);
    position: relative;
  }

  .app-features li::before {
    content: '✓';
    position: absolute;
    left: 0;
    color: var(--color-primary);
    font-weight: 700;
  }

  .nl-divider {
    width: 100%;
    border: none;
    border-top: 1px solid var(--color-border);
    margin: 0;
  }

  .app-card h3 {
    font-size: var(--text-h3);
    color: var(--color-primary);
    margin: 0;
  }

  .app-card p {
    font-size: var(--text-body);
    color: var(--color-text-secondary);
    line-height: var(--leading-body);
    margin: 0;
  }

  /* Newsletter signup */
  #nl-form-state,
  #nl-success-state {
    display: flex;
    flex-direction: column;
    gap: var(--space-s);
    width: 100%;
  }

  .nl-label {
    font-size: var(--text-small);
    font-weight: 600;
    color: var(--color-text-secondary);
    margin: 0;
  }

  .nl-subscribed {
    color: var(--color-success);
  }

  .nl-row {
    display: flex;
    gap: var(--space-s);
    align-items: center;
    width: 100%;
  }

  .nl-input {
    flex: 1;
    min-width: 0;
    padding: var(--space-s) var(--space-m);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-full);
    font-family: var(--font-body);
    font-size: var(--text-body);
    color: var(--color-text-primary);
    background: var(--color-white);
    outline: none;
    transition: border-color 0.15s;
  }

  .nl-input:focus {
    border-color: var(--color-primary);
    box-shadow: 0 0 0 2px var(--color-highlight);
  }

  .nl-btn {
    flex-shrink: 0;
    white-space: nowrap;
  }

  .nl-error {
    font-size: var(--text-small);
    color: var(--color-error);
    min-height: 1em;
    margin: 0;
    line-height: var(--leading-small);
  }

  .features {
    display: none; /* removed  -  replaced by section-anchors */
  }

  /* Section anchors */
  .section-anchors {
    background-color: var(--color-white);
    padding: var(--space-xxl) 0;
    border-bottom: 1px solid rgba(0, 0, 0, 0.06);
  }

  .anchors-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-l);
  }

  .anchor-card {
    background-color: var(--color-bg);
    border-radius: var(--radius-m);
    padding: var(--space-l);
    display: flex;
    flex-direction: column;
    gap: var(--space-s);
    border-left: 4px solid var(--color-primary);
  }

  .anchor-card-roi {
    border-left-color: var(--color-tab-active);
  }

  .anchor-card-homestead {
    border-left-color: var(--color-secondary);
  }

  .anchor-label {
    font-size: var(--text-small);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: var(--color-text-muted);
  }

  .anchor-title {
    font-size: var(--text-h3);
    font-weight: 700;
    color: var(--color-primary);
    text-decoration: none;
    line-height: 1.3;
  }

  .anchor-title:hover {
    color: var(--color-primary-light);
    text-decoration: underline;
  }

  .anchor-desc {
    font-size: var(--text-small);
    color: var(--color-text-muted);
    line-height: 1.5;
    margin: 0;
    flex: 1;
  }

  .anchor-link {
    font-size: var(--text-small);
    font-weight: 600;
    color: var(--color-primary);
    margin-top: var(--space-s);
  }

  .app-cta-actions {
    display: flex;
    flex-direction: column;
    gap: var(--space-m);
    align-items: flex-start;
  }

  .app-learn-more {
    font-size: var(--text-small);
    font-weight: 600;
    color: rgba(255, 255, 255, 0.75);
    text-decoration: none;
  }

  .app-learn-more:hover {
    color: var(--color-white);
    text-decoration: none;
  }

  .section {
    padding: var(--space-xxl) 0;
  }

  .section-alt {
    background-color: var(--color-white);
  }

  .glass-card {
    background: rgba(248, 249, 245, 0.98);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-radius: var(--radius-l);
    border: 1px solid rgba(255, 255, 255, 0.7);
    padding: var(--space-xl);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.18);
  }

  .section-card {
    padding: var(--space-l) 0;
  }

  .section-header-tight {
    margin-bottom: var(--space-m);
  }

  .section-fact {
    padding: var(--space-l) 0;
  }

  .section-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: var(--space-xl);
  }

  .section-link {
    font-size: var(--text-small);
    font-weight: 600;
    color: var(--color-primary);
  }

  .card-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-l);
  }

  .app-cta {
    position: relative;
    overflow: hidden;
    padding: var(--space-xxl) 0;
  }

  .app-cta::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(27, 61, 23, 0.82) 0%, rgba(45, 90, 39, 0.78) 100%);
  }

  .app-cta-inner {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1fr auto;
    gap: var(--space-xxl);
    align-items: center;
  }

  .app-cta-text {
    display: flex;
    flex-direction: column;
    gap: var(--space-m);
  }

  .app-cta-text h2 {
    font-family: var(--font-display);
    font-size: var(--text-screen-title);
    color: var(--color-white);
    margin: 0;
  }

  .app-cta-text p {
    font-size: var(--text-body);
    color: rgba(255,255,255,0.85);
    line-height: var(--leading-body);
    margin: 0;
    max-width: 520px;
  }

  .app-cta-visual img {
    border-radius: var(--radius-l);
    opacity: 0.9;
  }

  @media (max-width: 900px) {
    .hero-content {
      grid-template-columns: 1fr;
    }

    /* hero-app stays visible — stacks below hero text in single-column layout */

    .features-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .card-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .app-cta-inner {
      grid-template-columns: 1fr;
    }

    .app-cta-visual {
      display: none;
    }
  }

  @media (max-width: 680px) {
    /* Anchor cards (Crops / ROI / Homestead) stack vertically */
    .anchors-grid {
      grid-template-columns: 1fr;
    }

    .section-anchors {
      padding: var(--space-l) 0;
    }

    /* Hero subtitle shouldn't exceed viewport */
    .hero-subtitle {
      max-width: 100%;
    }
  }

  @media (max-width: 600px) {
    .features-grid,
    .card-grid {
      grid-template-columns: 1fr;
    }

    /* Tighten section padding on small phones */
    .section {
      padding: var(--space-l) 0;
    }

    .section-card {
      padding: var(--space-m) 0;
    }

    .section-fact {
      padding: var(--space-m) 0;
    }
  }
</style>

<script>
  const FORM_URL = 'https://docs.google.com/forms/d/e/1FAIpQLScewT4ZxcVIMnCaNscXeu6hWGWHRj_a6xwidloIDoYU9Sw8Bw/formResponse';
  const EMAIL_FIELD = 'entry.1425617156';
  const STORAGE_KEY = 'newsletter-subscribed';

  function showSuccess() {
    const formState = document.getElementById('nl-form-state');
    const successState = document.getElementById('nl-success-state');
    if (formState) formState.hidden = true;
    if (successState) successState.hidden = false;
  }

  // Already subscribed: hide the whole newsletter section, no point showing it
  try {
    if (localStorage.getItem(STORAGE_KEY) === 'true') {
      const section = document.getElementById('nl-section');
      if (section) section.hidden = true;
    }
  } catch (_) {}

  const submitBtn = document.getElementById('nl-submit') as HTMLButtonElement | null;
  const emailInput = document.getElementById('nl-email') as HTMLInputElement | null;
  const errorEl = document.getElementById('nl-error');

  submitBtn?.addEventListener('click', async () => {
    const email = emailInput?.value.trim() ?? '';

    // Client-side validation
    if (!email || !email.includes('@') || !email.includes('.')) {
      if (errorEl) errorEl.textContent = 'Please enter a valid email address.';
      return;
    }
    if (errorEl) errorEl.textContent = '';

    // Disable during fetch
    if (emailInput) emailInput.disabled = true;
    if (submitBtn) {
      submitBtn.disabled = true;
      submitBtn.textContent = 'Subscribing...';
    }

    try {
      const body = new URLSearchParams();
      body.set(EMAIL_FIELD, email);
      await fetch(FORM_URL, {
        method: 'POST',
        mode: 'no-cors',
        body,
      });
      // no-cors response is opaque — any non-throw is treated as success
      try { localStorage.setItem(STORAGE_KEY, 'true'); } catch (_) {}
      showSuccess();
    } catch (_) {
      // Network error
      if (emailInput) emailInput.disabled = false;
      if (submitBtn) {
        submitBtn.disabled = false;
        submitBtn.textContent = 'Subscribe';
      }
      if (errorEl) errorEl.textContent = 'Something went wrong. Try again.';
    }
  });
</script>
