---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { COMPARISON_PAIRS } from '../../data/comparisons';

const allPlants = await getCollection('plants');
const plantMap = new Map(allPlants.map((p) => [p.id, p]));

const pairs = COMPARISON_PAIRS.flatMap(([a, b]) => {
  const pa = plantMap.get(a);
  const pb = plantMap.get(b);
  if (!pa || !pb) return [];
  return [{ a: pa, b: pb, slug: `${a}-vs-${b}` }];
});

// Sort by name
const sorted = [...allPlants].sort((a, b) => a.data.name.localeCompare(b.data.name));

// Serialize plant data for client-side comparison
const plantData = Object.fromEntries(
  allPlants.map((p) => [
    p.id,
    {
      id: p.id,
      name: p.data.name,
      seed_cost: p.data.seed_cost,
      days_min: p.data.days_min,
      days_max: p.data.days_max,
      avg_yield_lb: p.data.avg_yield_lb,
      avg_price_lb: p.data.avg_price_lb,
    },
  ])
);
const plantDataJson = JSON.stringify(plantData);
---

<BaseLayout
  title="Compare Crops: Side-by-Side ROI & Yield"
  description="Compare any two garden crops side by side: seed cost, yield, retail value, and net ROI. Find which crops give you the best return."
>
  <div class="page-header">
    <div class="container">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <ol>
          <li><a href="/">Home</a></li>
          <li><a href="/plan/">Plan</a></li>
          <li aria-current="page">Compare Crops</li>
        </ol>
      </nav>
      <h1>Compare Crops</h1>
      <p>Pick two crops to see a side-by-side breakdown of seed cost, yield, retail value, and ROI.</p>
    </div>
  </div>

  <div class="container compare-index">
    <!-- Baked-in plant data for client-side comparison -->
    <script id="compare-data" type="application/json" set:html={plantDataJson}></script>

    <!-- Custom comparison picker -->
    <div class="glass-card picker-card">
      <h2>Build a comparison</h2>
      <div class="picker-row">
        <select id="pick-a" class="pick-select" aria-label="First crop">
          <option value="">— Crop 1 —</option>
          {sorted.map((p) => <option value={p.id}>{p.data.name}</option>)}
        </select>
        <span class="vs-label">vs</span>
        <select id="pick-b" class="pick-select" aria-label="Second crop">
          <option value="">— Crop 2 —</option>
          {sorted.map((p) => <option value={p.id}>{p.data.name}</option>)}
        </select>
        <button id="pick-go" class="btn btn-primary" disabled>Compare</button>
      </div>
    </div>

    <!-- Inline result panel -->
    <div id="compare-result" class="glass-card compare-result" hidden>
      <h2 id="result-title" class="result-title"></h2>
      <div class="prose">
        <table>
          <thead>
            <tr>
              <th>Metric</th>
              <th id="result-head-a"></th>
              <th id="result-head-b"></th>
            </tr>
          </thead>
          <tbody id="result-tbody"></tbody>
        </table>
      </div>
      <p class="table-note">Values are per plant/packet. Retail prices from USDA AMS data. Net value = gross harvest value minus seed cost.</p>
      <div class="crop-links" id="result-crop-links"></div>
    </div>

    <script>
      interface PlantRow { id: string; name: string; seed_cost: number; days_min: number; days_max: number; avg_yield_lb: number; avg_price_lb: number; }

      const raw = document.getElementById('compare-data')?.textContent ?? '{}';
      const plantMap: Record<string, PlantRow> = JSON.parse(raw);

      const pickA   = document.getElementById('pick-a')          as HTMLSelectElement | null;
      const pickB   = document.getElementById('pick-b')          as HTMLSelectElement | null;
      const pickGo  = document.getElementById('pick-go')         as HTMLButtonElement | null;
      const result  = document.getElementById('compare-result')  as HTMLElement | null;
      const titleEl = document.getElementById('result-title')    as HTMLElement | null;
      const headA   = document.getElementById('result-head-a')   as HTMLElement | null;
      const headB   = document.getElementById('result-head-b')   as HTMLElement | null;
      const tbody   = document.getElementById('result-tbody')    as HTMLElement | null;
      const links   = document.getElementById('result-crop-links') as HTMLElement | null;

      function fmt2(n: number) { return '$' + n.toFixed(2); }

      function render() {
        const a = plantMap[pickA?.value ?? ''];
        const b = plantMap[pickB?.value ?? ''];
        if (!a || !b || !result) return;

        const grossA = a.avg_yield_lb * a.avg_price_lb;
        const grossB = b.avg_yield_lb * b.avg_price_lb;
        const netA   = grossA - a.seed_cost;
        const netB   = grossB - b.seed_cost;
        const roiA   = grossA / a.seed_cost;
        const roiB   = grossB / b.seed_cost;

        const metrics = [
          { label: 'Seed cost',           va: fmt2(a.seed_cost),      vb: fmt2(b.seed_cost),      winA: a.seed_cost < b.seed_cost,  winB: b.seed_cost < a.seed_cost },
          { label: 'Days to maturity',    va: `${a.days_min}–${a.days_max}`, vb: `${b.days_min}–${b.days_max}`, winA: a.days_max < b.days_max, winB: b.days_max < a.days_max },
          { label: 'Avg yield (lb)',      va: `${a.avg_yield_lb} lb`, vb: `${b.avg_yield_lb} lb`, winA: a.avg_yield_lb > b.avg_yield_lb, winB: b.avg_yield_lb > a.avg_yield_lb },
          { label: 'Retail price/lb',     va: fmt2(a.avg_price_lb),   vb: fmt2(b.avg_price_lb),   winA: a.avg_price_lb > b.avg_price_lb, winB: b.avg_price_lb > a.avg_price_lb },
          { label: 'Gross harvest value', va: fmt2(grossA),           vb: fmt2(grossB),           winA: grossA > grossB,             winB: grossB > grossA },
          { label: 'Net value',           va: fmt2(netA),             vb: fmt2(netB),             winA: netA > netB,                 winB: netB > netA },
          { label: 'ROI multiple',        va: roiA.toFixed(1) + '×',  vb: roiB.toFixed(1) + '×',  winA: roiA > roiB,                 winB: roiB > roiA },
        ];

        if (titleEl) titleEl.textContent = `${a.name} vs ${b.name}`;
        if (headA)   headA.textContent   = a.name;
        if (headB)   headB.textContent   = b.name;

        if (tbody) {
          tbody.innerHTML = metrics.map((m) => `
            <tr>
              <td class="metric-label">${m.label}</td>
              <td class="crop-val crop-a-val${m.winA ? ' winner' : ''}">${m.va}</td>
              <td class="crop-val crop-b-val${m.winB ? ' winner' : ''}">${m.vb}</td>
            </tr>
          `).join('');
        }

        if (links) {
          links.innerHTML = `
            <a href="/crops/${a.id}/" class="btn btn-secondary">Full ${a.name} guide →</a>
            <a href="/crops/${b.id}/" class="btn btn-secondary">Full ${b.name} guide →</a>
          `;
        }

        result.hidden = false;
        result.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
      }

      function updateButton() {
        if (pickA && pickB && pickGo) {
          pickGo.disabled = !pickA.value || !pickB.value || pickA.value === pickB.value;
        }
      }

      pickA?.addEventListener('change', updateButton);
      pickB?.addEventListener('change', updateButton);
      pickGo?.addEventListener('click', render);
    </script>

    <!-- Pre-rendered pairs -->
    <h2 class="section-heading">Popular comparisons</h2>
    <div class="pairs-grid">
      {pairs.map(({ a, b, slug }) => {
        const aGross = (a.data.avg_yield_lb * a.data.avg_price_lb).toFixed(2);
        const bGross = (b.data.avg_yield_lb * b.data.avg_price_lb).toFixed(2);
        return (
          <a href={`/compare/${slug}/`} class="pair-card glass-card">
            <div class="pair-names">
              <span class="pair-name crop-a-name">{a.data.name}</span>
              <span class="pair-vs">vs</span>
              <span class="pair-name crop-b-name">{b.data.name}</span>
            </div>
            <div class="pair-stats">
              <span class="pair-stat">
                <span class="pair-stat-val crop-a-val">${aGross}</span>
                <span class="pair-stat-label">est. value</span>
              </span>
              <span class="pair-divider">|</span>
              <span class="pair-stat">
                <span class="pair-stat-val crop-b-val">${bGross}</span>
                <span class="pair-stat-label">est. value</span>
              </span>
            </div>
          </a>
        );
      })}
    </div>
  </div>
</BaseLayout>

<style>
  .breadcrumb ol {
    display: flex;
    gap: var(--space-xs);
    list-style: none;
    padding: 0;
    margin: 0 0 var(--space-m);
    font-size: var(--text-small);
  }

  .breadcrumb li {
    display: flex;
    align-items: center;
    gap: var(--space-xs);
    color: rgba(255, 255, 255, 0.7);
  }

  .breadcrumb li:not(:last-child)::after {
    content: '/';
    color: rgba(255, 255, 255, 0.4);
  }

  .breadcrumb a {
    color: rgba(255, 255, 255, 0.85);
    text-decoration: none;
  }

  .breadcrumb a:hover {
    color: var(--color-white);
    text-decoration: underline;
  }

  .compare-index {
    padding-top: var(--space-xl);
    padding-bottom: var(--space-xxl);
    background-color: rgba(248, 249, 245, 0.97);
  }

  .picker-card {
    padding: var(--space-l);
    margin-bottom: var(--space-xl);
  }

  .picker-card h2 {
    font-family: var(--font-display);
    color: var(--color-primary);
    margin-bottom: var(--space-m);
  }

  .picker-row {
    display: flex;
    align-items: center;
    gap: var(--space-m);
    flex-wrap: wrap;
  }

  .pick-select {
    font-family: var(--font-body);
    font-size: var(--text-body);
    padding: var(--space-s) var(--space-m);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-s);
    background: var(--color-white);
    color: var(--color-text-primary);
    min-width: 180px;
  }

  .vs-label {
    font-weight: 700;
    color: var(--color-text-muted);
    font-size: var(--text-small);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .section-heading {
    font-family: var(--font-display);
    font-size: var(--text-h2);
    color: var(--color-primary);
    margin-bottom: var(--space-l);
  }

  .pairs-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: var(--space-l);
  }

  .pair-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-m);
    padding: var(--space-l);
    text-decoration: none;
    color: inherit;
    transition: transform 0.15s, box-shadow 0.15s;
  }

  .pair-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-card);
  }

  .pair-names {
    display: flex;
    align-items: center;
    gap: var(--space-s);
    flex-wrap: wrap;
  }

  .pair-name {
    font-weight: 700;
    font-size: var(--text-body);
  }

  .crop-a-name { color: var(--color-primary); }
  .crop-b-name { color: var(--color-secondary); }

  .pair-vs {
    font-size: var(--text-small);
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .pair-stats {
    display: flex;
    align-items: center;
    gap: var(--space-m);
    font-size: var(--text-small);
  }

  .pair-stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2px;
  }

  .pair-stat-val {
    font-weight: 700;
    font-variant-numeric: tabular-nums;
  }

  .crop-a-val { color: var(--color-primary); }
  .crop-b-val { color: var(--color-secondary); }

  .pair-stat-label { color: var(--color-text-muted); font-size: var(--text-micro); text-transform: uppercase; }

  .pair-divider { color: var(--color-border); }

  /* Inline result panel */
  .compare-result {
    padding: var(--space-l);
    margin-bottom: var(--space-xl);
  }

  .result-title {
    font-family: var(--font-display);
    font-size: var(--text-h2);
    color: var(--color-primary);
    margin-bottom: var(--space-l);
  }

  .table-note {
    font-size: var(--text-small);
    color: var(--color-text-muted);
    margin-top: var(--space-m);
  }

  .crop-links {
    display: flex;
    gap: var(--space-m);
    flex-wrap: wrap;
    margin-top: var(--space-l);
  }
</style>
