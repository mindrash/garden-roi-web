---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { COMPARISON_PAIRS } from '../../data/comparisons';

const allPlants = await getCollection('plants');
const plantMap = new Map(allPlants.map((p) => [p.id, p]));

const pairs = COMPARISON_PAIRS.flatMap(([a, b]) => {
  const pa = plantMap.get(a);
  const pb = plantMap.get(b);
  if (!pa || !pb) return [];
  return [{ a: pa, b: pb, slug: `${a}-vs-${b}` }];
});

// Sort alphabetically for dropdowns
const sorted = [...allPlants].sort((a, b) => a.data.name.localeCompare(b.data.name));

// Serialize all plant data for client-side comparison rendering
const plantData = Object.fromEntries(
  allPlants.map((p) => [
    p.id,
    {
      id: p.id,
      name: p.data.name,
      seed_cost: p.data.seed_cost,
      days_min: p.data.days_min,
      days_max: p.data.days_max,
      avg_yield_lb: p.data.avg_yield_lb,
      avg_price_lb: p.data.avg_price_lb,
    },
  ])
);
---

<BaseLayout
  title="Compare Crops: Side-by-Side ROI & Yield"
  description="Compare any two garden crops side by side: seed cost, yield, retail value, and net ROI. Find which crops give you the best return."
>
  <div class="page-header">
    <div class="container">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <ol>
          <li><a href="/">Home</a></li>
          <li><a href="/plan/">Plan</a></li>
          <li aria-current="page">Compare Crops</li>
        </ol>
      </nav>
      <h1>Compare Crops</h1>
      <p>Pick two crops to see a side-by-side breakdown of seed cost, yield, retail value, and ROI.</p>
    </div>
  </div>

  <div class="container compare-index">
    <!-- Custom comparison picker -->
    <div class="glass-card picker-card">
      <h2>Build a comparison</h2>
      <div class="picker-row">
        <select id="pick-a" class="pick-select" aria-label="First crop">
          <option value="">— Crop 1 —</option>
          {sorted.map((p) => <option value={p.id}>{p.data.name}</option>)}
        </select>
        <span class="vs-label">vs</span>
        <select id="pick-b" class="pick-select" aria-label="Second crop">
          <option value="">— Crop 2 —</option>
          {sorted.map((p) => <option value={p.id}>{p.data.name}</option>)}
        </select>
        <button id="pick-go" class="btn btn-primary" disabled>Compare</button>
      </div>
    </div>

    <!-- Inline comparison result panel (hidden until a comparison is run) -->
    <div id="compare-result" class="compare-result" hidden aria-live="polite">
      <h2 id="result-title" class="result-title"></h2>
      <p class="result-desc">Side-by-side ROI comparison based on USDA average yield and retail price data.</p>
      <div class="prose" id="result-prose">
        <table id="result-table">
          <thead>
            <tr>
              <th>Metric</th>
              <th class="crop-a-head" id="result-head-a"></th>
              <th class="crop-b-head" id="result-head-b"></th>
            </tr>
          </thead>
          <tbody id="result-tbody"></tbody>
        </table>
      </div>
      <p class="table-note">Values are per plant/packet. Retail prices from USDA AMS data. Net value = gross harvest value minus seed cost.</p>
      <div class="crop-links" id="result-crop-links"></div>
    </div>

    <!-- Pre-rendered featured pairs -->
    <h2 class="section-heading">Popular comparisons</h2>
    <div class="pairs-grid">
      {pairs.map(({ a, b, slug }) => {
        const aGross = (a.data.avg_yield_lb * a.data.avg_price_lb).toFixed(2);
        const bGross = (b.data.avg_yield_lb * b.data.avg_price_lb).toFixed(2);
        return (
          <a href={`/compare/${slug}/`} class="pair-card glass-card">
            <div class="pair-names">
              <span class="pair-name crop-a-name">{a.data.name}</span>
              <span class="pair-vs">vs</span>
              <span class="pair-name crop-b-name">{b.data.name}</span>
            </div>
            <div class="pair-stats">
              <span class="pair-stat">
                <span class="pair-stat-val crop-a-val">${aGross}</span>
                <span class="pair-stat-label">est. value</span>
              </span>
              <span class="pair-divider">|</span>
              <span class="pair-stat">
                <span class="pair-stat-val crop-b-val">${bGross}</span>
                <span class="pair-stat-label">est. value</span>
              </span>
            </div>
          </a>
        );
      })}
    </div>
  </div>
</BaseLayout>

<script define:vars={{ plantData }}>
  const pickA = document.getElementById('pick-a');
  const pickB = document.getElementById('pick-b');
  const pickGo = document.getElementById('pick-go');
  const resultPanel = document.getElementById('compare-result');
  const resultTitle = document.getElementById('result-title');
  const resultHeadA = document.getElementById('result-head-a');
  const resultHeadB = document.getElementById('result-head-b');
  const resultTbody = document.getElementById('result-tbody');
  const resultCropLinks = document.getElementById('result-crop-links');

  function updateButton() {
    const aVal = pickA.value;
    const bVal = pickB.value;
    pickGo.disabled = !aVal || !bVal || aVal === bVal;
  }

  pickA.addEventListener('change', updateButton);
  pickB.addEventListener('change', updateButton);

  function fmt2(n) { return '$' + n.toFixed(2); }
  function grossValue(p) { return p.avg_yield_lb * p.avg_price_lb; }
  function netValue(p)   { return grossValue(p) - p.seed_cost; }
  function roiMultiple(p) { return grossValue(p) / p.seed_cost; }

  function winner(aVal, bVal, higherWins) {
    if (aVal === bVal) return 'tie';
    if (higherWins) return aVal > bVal ? 'a' : 'b';
    return aVal < bVal ? 'a' : 'b';
  }

  function renderComparison(aId, bId) {
    const a = plantData[aId];
    const b = plantData[bId];
    if (!a || !b) return;

    const metrics = [
      { label: 'Seed cost',           aStr: fmt2(a.seed_cost),          bStr: fmt2(b.seed_cost),          w: winner(a.seed_cost, b.seed_cost, false) },
      { label: 'Days to maturity',    aStr: `${a.days_min}\u2013${a.days_max}`, bStr: `${b.days_min}\u2013${b.days_max}`, w: winner(a.days_max, b.days_max, false) },
      { label: 'Avg yield (lb)',      aStr: `${a.avg_yield_lb} lb`,      bStr: `${b.avg_yield_lb} lb`,      w: winner(a.avg_yield_lb, b.avg_yield_lb, true) },
      { label: 'Retail price/lb',     aStr: fmt2(a.avg_price_lb),        bStr: fmt2(b.avg_price_lb),        w: winner(a.avg_price_lb, b.avg_price_lb, true) },
      { label: 'Gross harvest value', aStr: fmt2(grossValue(a)),          bStr: fmt2(grossValue(b)),          w: winner(grossValue(a), grossValue(b), true) },
      { label: 'Net value',           aStr: fmt2(netValue(a)),            bStr: fmt2(netValue(b)),            w: winner(netValue(a), netValue(b), true) },
      { label: 'ROI multiple',        aStr: `${roiMultiple(a).toFixed(1)}\u00d7`, bStr: `${roiMultiple(b).toFixed(1)}\u00d7`, w: winner(roiMultiple(a), roiMultiple(b), true) },
    ];

    resultTitle.textContent = `${a.name} vs ${b.name}`;

    resultHeadA.innerHTML = `<a href="/crops/${a.id}/">${a.name}</a>`;
    resultHeadB.innerHTML = `<a href="/crops/${b.id}/">${b.name}</a>`;

    resultTbody.innerHTML = metrics.map((m) => `
      <tr>
        <td><strong>${m.label}</strong></td>
        <td class="${m.w === 'a' ? 'winner-cell' : ''}">${m.aStr}</td>
        <td class="${m.w === 'b' ? 'winner-cell' : ''}">${m.bStr}</td>
      </tr>
    `).join('');

    resultCropLinks.innerHTML = `
      <a href="/crops/${a.id}/" class="btn btn-secondary">Full ${a.name} guide &rarr;</a>
      <a href="/crops/${b.id}/" class="btn btn-secondary">Full ${b.name} guide &rarr;</a>
    `;

    resultPanel.hidden = false;
    resultPanel.scrollIntoView({ behavior: 'smooth', block: 'start' });
  }

  pickGo.addEventListener('click', () => {
    if (pickA.value && pickB.value) {
      renderComparison(pickA.value, pickB.value);
    }
  });
</script>

<style>
  .breadcrumb ol {
    display: flex;
    gap: var(--space-xs);
    list-style: none;
    padding: 0;
    margin: 0 0 var(--space-m);
    font-size: var(--text-small);
  }

  .breadcrumb li {
    display: flex;
    align-items: center;
    gap: var(--space-xs);
    color: rgba(255, 255, 255, 0.7);
  }

  .breadcrumb li:not(:last-child)::after {
    content: '/';
    color: rgba(255, 255, 255, 0.4);
  }

  .breadcrumb a {
    color: rgba(255, 255, 255, 0.85);
    text-decoration: none;
  }

  .breadcrumb a:hover {
    color: var(--color-white);
    text-decoration: underline;
  }

  .compare-index {
    padding-top: var(--space-xl);
    padding-bottom: var(--space-xxl);
    background-color: rgba(248, 249, 245, 0.97);
  }

  .picker-card {
    padding: var(--space-l);
    margin-bottom: var(--space-xl);
  }

  .picker-card h2 {
    font-family: var(--font-display);
    color: var(--color-primary);
    margin-bottom: var(--space-m);
  }

  .picker-row {
    display: flex;
    align-items: center;
    gap: var(--space-m);
    flex-wrap: wrap;
  }

  .pick-select {
    font-family: var(--font-body);
    font-size: var(--text-body);
    padding: var(--space-s) var(--space-m);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-s);
    background: var(--color-white);
    color: var(--color-text-primary);
    min-width: 180px;
  }

  .vs-label {
    font-weight: 700;
    color: var(--color-text-muted);
    font-size: var(--text-small);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  /* Inline comparison result */
  .compare-result {
    margin-bottom: var(--space-xl);
    scroll-margin-top: var(--space-xl);
  }

  .result-title {
    font-family: var(--font-display);
    font-size: var(--text-h2);
    color: var(--color-primary);
    margin-bottom: var(--space-s);
  }

  .result-desc {
    color: var(--color-text-secondary);
    margin-bottom: var(--space-l);
  }

  /* Winner cell - supplements prose table styles */
  .winner-cell {
    font-weight: 700;
    color: var(--color-primary-dark);
    background-color: rgba(76, 175, 80, 0.12);
  }

  /* Crop column headers get distinct brand colors */
  #result-prose thead th.crop-a-head {
    background-color: var(--color-primary-dark);
  }

  #result-prose thead th.crop-b-head {
    background-color: var(--color-secondary);
  }


  .table-note {
    font-size: var(--text-small);
    color: var(--color-text-muted);
    margin-top: calc(-1 * var(--space-s));
    margin-bottom: var(--space-l);
  }

  .crop-links {
    display: flex;
    gap: var(--space-m);
    flex-wrap: wrap;
    margin-bottom: var(--space-xl);
  }

  /* Featured pairs */
  .section-heading {
    font-family: var(--font-display);
    font-size: var(--text-h2);
    color: var(--color-primary);
    margin-bottom: var(--space-l);
  }

  .pairs-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: var(--space-l);
  }

  .pair-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-m);
    padding: var(--space-l);
    text-decoration: none;
    color: inherit;
    transition: transform 0.15s, box-shadow 0.15s;
  }

  .pair-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-card);
  }

  .pair-names {
    display: flex;
    align-items: center;
    gap: var(--space-s);
    flex-wrap: wrap;
  }

  .pair-name {
    font-weight: 700;
    font-size: var(--text-body);
  }

  .crop-a-name { color: var(--color-primary); }
  .crop-b-name { color: var(--color-secondary); }

  .pair-vs {
    font-size: var(--text-small);
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .pair-stats {
    display: flex;
    align-items: center;
    gap: var(--space-m);
    font-size: var(--text-small);
  }

  .pair-stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2px;
  }

  .pair-stat-val {
    font-weight: 700;
    font-variant-numeric: tabular-nums;
  }

  .crop-a-val { color: var(--color-primary); }
  .crop-b-val { color: var(--color-secondary); }

  .pair-stat-label { color: var(--color-text-muted); font-size: var(--text-micro); text-transform: uppercase; }

  .pair-divider { color: var(--color-border); }
</style>
