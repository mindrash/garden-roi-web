---
import ContentLayout from '../../layouts/ContentLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const articles = await getCollection('articles');
  return articles.map((article) => ({
    params: { slug: article.id },
    props: { article },
  }));
}

const { article } = Astro.props;
const { Content } = await render(article);

const { title, description, category, publishDate, featured } = article.data;

const categoryLabels: Record<string, string> = {
  homestead: 'Homestead',
  roi: 'ROI & Budgeting',
  care: 'Plant Care',
  planning: 'Planning',
};

const formattedDate = publishDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<ContentLayout
  title={title}
  description={description}
  breadcrumbs={[{ label: 'Tips & Guides', href: '/tips/' }]}
>
  <article class="article-detail">
    <header class="article-header">
      <div class="article-meta">
        <span class={`tag tag-${category}`}>{categoryLabels[category]}</span>
        {featured && <span class="tag" style="background: var(--color-highlight); color: var(--color-primary);">Featured</span>}
        <time datetime={publishDate.toISOString()} class="article-date">{formattedDate}</time>
      </div>
      <h1 class="article-title">{title}</h1>
      <p class="article-description">{description}</p>
    </header>

    <div class="prose article-body">
      <Content />
    </div>

    <footer class="article-footer">
      <a href="/tips/" class="btn btn-outline">← All Guides</a>
      <a href="/#download" class="btn btn-primary">Track in the App</a>
    </footer>
  </article>
</ContentLayout>

<style>
  .article-detail {
    display: flex;
    flex-direction: column;
    gap: var(--space-xl);
  }

  .article-header {
    display: flex;
    flex-direction: column;
    gap: var(--space-m);
    padding-bottom: var(--space-l);
    border-bottom: 1px solid rgba(0,0,0,0.08);
  }

  .article-meta {
    display: flex;
    align-items: center;
    gap: var(--space-m);
    flex-wrap: wrap;
  }

  .article-date {
    font-size: var(--text-small);
    color: var(--color-text-muted);
  }

  .article-title {
    font-family: var(--font-body);
    font-size: var(--text-h1);
    font-weight: 700;
    line-height: var(--leading-h1);
    color: var(--color-text-primary);
    margin: 0;
  }

  .article-description {
    font-size: var(--text-body);
    color: var(--color-text-secondary);
    line-height: var(--leading-body);
    margin: 0;
    max-width: 640px;
  }

  .article-body {
    padding-bottom: var(--space-l);
  }

  .article-footer {
    display: flex;
    gap: var(--space-m);
    flex-wrap: wrap;
    padding-top: var(--space-l);
    border-top: 1px solid rgba(0,0,0,0.08);
  }
</style>
