---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import { getCollection } from 'astro:content';

const allArticles = await getCollection('articles');

const articles = allArticles.sort(
  (a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime()
);

const categoryLabels: Record<string, string> = {
  homestead: 'Homestead',
  roi: 'ROI & Budgeting',
  care: 'Plant Care',
  planning: 'Planning',
};

const categories = ['homestead', 'roi', 'care', 'planning'] as const;
---

<BaseLayout
  title="Tips & Guides"
  description="Practical guides for home gardeners — plant care, ROI strategies, homesteading skills, and garden planning."
>
  <div class="page-header">
    <div class="container">
      <h1>Tips & Guides</h1>
      <p>Practical advice for growing more food, spending less money, and building lasting garden skills.</p>
    </div>
  </div>

  <div class="container tips-page">
    <!-- Filter bar -->
    <div class="filter-bar">
      <a href="/tips/" class="filter-btn" data-category="All">All</a>
      {categories.map((cat) => (
        <a href={`/tips/?category=${cat}`} class="filter-btn" data-category={cat}>
          {categoryLabels[cat]}
        </a>
      ))}
    </div>

    <div class="articles-grid" id="articles-grid">
      {articles.map((article) => (
        <div data-category={article.data.category} class="article-item">
          <ArticleCard
            slug={article.id}
            title={article.data.title}
            description={article.data.description}
            category={article.data.category}
            publishDate={article.data.publishDate}
            featured={article.data.featured}
          />
        </div>
      ))}
    </div>
  </div>
</BaseLayout>

<script>
  const params = new URLSearchParams(window.location.search);
  const active = params.get('category') || 'All';

  document.querySelectorAll<HTMLElement>('.filter-btn').forEach((btn) => {
    if (btn.dataset.category === active) {
      btn.classList.add('active');
    }
  });

  if (active !== 'All') {
    document.querySelectorAll<HTMLElement>('.article-item').forEach((item) => {
      if (item.dataset.category !== active) {
        item.style.display = 'none';
      }
    });
  }
</script>

<style>
  .page-header {
    background: linear-gradient(135deg, var(--color-secondary) 0%, var(--color-secondary-light) 100%);
    padding: var(--space-xxl) 0 var(--space-xl);
  }

  .page-header h1 {
    font-family: var(--font-display);
    color: var(--color-white);
    font-size: var(--text-screen-title);
    margin-bottom: var(--space-s);
  }

  .page-header p {
    color: rgba(255,255,255,0.85);
    font-size: var(--text-body);
    margin: 0;
  }

  .tips-page {
    padding: var(--space-xl) var(--space-l);
  }

  .filter-bar {
    display: flex;
    gap: var(--space-s);
    margin-bottom: var(--space-xl);
    flex-wrap: wrap;
  }

  .filter-btn {
    padding: var(--space-xs) var(--space-m);
    border-radius: var(--radius-full);
    border: 2px solid var(--color-secondary);
    color: var(--color-secondary);
    font-size: var(--text-small);
    font-weight: 600;
    text-decoration: none;
    transition: background-color 0.2s, color 0.2s;
    background: transparent;
  }

  .filter-btn:hover,
  .filter-btn.active {
    background-color: var(--color-secondary);
    color: var(--color-white);
    text-decoration: none;
  }

  .articles-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-l);
  }

  @media (max-width: 900px) {
    .articles-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 600px) {
    .articles-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
