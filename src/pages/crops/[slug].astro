---
import ContentLayout from '../../layouts/ContentLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const plants = await getCollection('plants');
  return plants.map((plant) => ({
    params: { slug: plant.id },
    props: { plant },
  }));
}

const { plant } = Astro.props;
const { Content } = await render(plant);

const {
  name,
  scientific_name,
  category,
  days_min,
  days_max,
  avg_yield_lb,
  avg_price_lb,
  watering,
  sunlight,
  companion_plants,
} = plant.data;

const roiEstimate = (avg_yield_lb * avg_price_lb).toFixed(2);
const tagClass = `tag tag-${category.toLowerCase()}`;

const cropDescription = plant.data.description ?? `Complete care guide for ${name} (${scientific_name})  -  growing tips, ROI breakdown, watering, sunlight, and companion plants.`;
const cropImage = plant.data.hero_image
  ? new URL(plant.data.hero_image, Astro.site).toString()
  : new URL('/logo.png', Astro.site).toString();

const articleJsonLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": `${name}: ROI, Yield & Growing Guide`,
  "description": cropDescription,
  "image": cropImage,
  "publisher": {
    "@type": "Organization",
    "name": "Garden ROI",
    "logo": { "@type": "ImageObject", "url": new URL('/logo.png', Astro.site).toString() },
  },
};
---

<ContentLayout
  title={`${name}: ROI, Yield & Growing Guide`}
  description={cropDescription}
  ogImage={plant.data.hero_image}
  breadcrumbs={[{ label: 'Crops', href: '/crops/' }]}
  pageJsonLd={articleJsonLd}
>
  <div class="plant-detail" data-pagefind-body>
    <!-- Header -->
    <div class="plant-header">
      <span class={tagClass}>{category}</span>
      <h1 class="plant-title">{name}</h1>
      <p class="plant-scientific">{scientific_name}</p>
    </div>

    <!-- Stats grid -->
    <div class="stats-grid">
      <div class="stat-card">
        <span class="stat-value">{days_min}–{days_max}</span>
        <span class="stat-label">Days to Harvest</span>
      </div>
      <div class="stat-card">
        <span class="stat-value">{avg_yield_lb} lb</span>
        <span class="stat-label">Avg Yield</span>
      </div>
      <div class="stat-card">
        <span class="stat-value">${avg_price_lb}/lb</span>
        <span class="stat-label">Grocery Value</span>
      </div>
      <div class="stat-card stat-card-highlight">
        <span class="stat-value">${roiEstimate}</span>
        <span class="stat-label">Est. Harvest Value</span>
      </div>
    </div>

    <!-- Quick facts -->
    <div class="quick-facts">
      <div class="fact">
        <span class="fact-label">💧 Watering</span>
        <span class="fact-value">{watering}</span>
      </div>
      <div class="fact">
        <span class="fact-label">☀️ Sunlight</span>
        <span class="fact-value">{sunlight}</span>
      </div>
      {companion_plants.length > 0 && (
        <div class="fact">
          <span class="fact-label">🌿 Companions</span>
          <span class="fact-value">{companion_plants.join(', ')}</span>
        </div>
      )}
    </div>

    <!-- Article body -->
    <div class="prose plant-body">
      <Content />
    </div>

    <!-- Track CTA -->
    <div class="track-cta">
      <p>Growing {name}? Track your harvest value and break-even date in the Garden ROI app.</p>
      <a href="/#download" class="btn btn-primary">Get the App</a>
    </div>
  </div>
</ContentLayout>

<style>
  .plant-detail {
    display: flex;
    flex-direction: column;
    gap: var(--space-xl);
  }

  .plant-header {
    display: flex;
    flex-direction: column;
    gap: var(--space-s);
    padding-bottom: var(--space-l);
    border-bottom: 1px solid rgba(0,0,0,0.08);
  }

  .plant-title {
    font-family: var(--font-display);
    font-size: var(--text-screen-title);
    line-height: var(--leading-screen-title);
    color: var(--color-primary);
    margin: 0;
  }

  .plant-scientific {
    font-size: var(--text-body);
    color: var(--color-text-muted);
    font-style: italic;
    margin: 0;
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-m);
  }

  .stat-card {
    background-color: var(--color-bg);
    border-radius: var(--radius-m);
    padding: var(--space-m);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-xs);
    text-align: center;
  }

  .stat-card-highlight {
    background-color: var(--color-highlight);
    border: 1px solid rgba(45, 90, 39, 0.15);
  }

  .stat-value {
    font-size: var(--text-h2);
    font-weight: 700;
    color: var(--color-primary);
    line-height: 1.2;
  }

  .stat-label {
    font-size: var(--text-small);
    color: var(--color-text-muted);
    line-height: 1.3;
  }

  .quick-facts {
    display: flex;
    flex-direction: column;
    gap: var(--space-s);
    background-color: var(--color-white);
    border-radius: var(--radius-m);
    padding: var(--space-l);
    border: 1px solid rgba(0,0,0,0.06);
  }

  .fact {
    display: flex;
    gap: var(--space-m);
    align-items: baseline;
  }

  .fact-label {
    font-size: var(--text-small);
    font-weight: 600;
    color: var(--color-text-secondary);
    min-width: 140px;
  }

  .fact-value {
    font-size: var(--text-small);
    color: var(--color-text-muted);
  }

  .plant-body {
    padding-top: var(--space-m);
  }

  .track-cta {
    background: linear-gradient(135deg, var(--color-primary-dark), var(--color-primary));
    border-radius: var(--radius-m);
    padding: var(--space-xl);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-l);
    flex-wrap: wrap;
  }

  .track-cta p {
    color: rgba(255,255,255,0.9);
    font-size: var(--text-body);
    margin: 0;
    max-width: 500px;
  }

  @media (max-width: 700px) {
    .stats-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 480px) {
    .stats-grid {
      grid-template-columns: 1fr 1fr;
    }

    .fact {
      flex-direction: column;
      gap: var(--space-xs);
    }
  }
</style>
