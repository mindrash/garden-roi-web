---
import ContentLayout from '../../layouts/ContentLayout.astro';
import PlantCard from '../../components/PlantCard.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const plants = await getCollection('plants');
  const allArticles = await getCollection('articles');
  return plants.map((plant) => ({
    params: { slug: plant.id },
    props: { plant, allPlants: plants, allArticles },
  }));
}

const { plant, allPlants, allArticles } = Astro.props;
const { Content } = await render(plant);

const {
  name,
  scientific_name,
  category,
  days_min,
  days_max,
  avg_yield_lb,
  avg_price_lb,
  watering,
  sunlight,
  companion_plants,
} = plant.data;

// M002: build slug lookup for companion plant linking
const plantSlugs = new Set(allPlants.map((p) => p.id));
function nameToSlug(n: string): string {
  return n.toLowerCase().replace(/\s+/g, '-');
}

// Related crops: same category, sorted by ROI, top 3
const relatedCrops = allPlants
  .filter((p) => p.id !== plant.id && p.data.category === category)
  .sort((a, b) => {
    const roiA = (a.data.avg_yield_lb * a.data.avg_price_lb) / a.data.start_cost;
    const roiB = (b.data.avg_yield_lb * b.data.avg_price_lb) / b.data.start_cost;
    return roiB - roiA;
  })
  .slice(0, 3);

// M003: find related articles (crop name match first, then category)
const nameLower = name.toLowerCase();
function sectionPath(cat: string): string {
  if (cat === 'roi') return '/roi';
  if (cat === 'homestead') return '/homestead';
  return '/guides';
}
const relatedArticles = allArticles
  .filter((a) => {
    const t = a.data.title.toLowerCase();
    const d = (a.data.description ?? '').toLowerCase();
    return t.includes(nameLower) || d.includes(nameLower);
  })
  .slice(0, 3);

const roiEstimate = (avg_yield_lb * avg_price_lb).toFixed(2);
const tagClass = `tag tag-${category.toLowerCase()}`;

// S001: FAQPage JSON-LD for top 20 crops by ROI
const top20Ids = new Set(
  [...allPlants]
    .filter((p) => p.data.start_cost > 0)
    .sort((a, b) => {
      const roiA = (a.data.avg_yield_lb * a.data.avg_price_lb) / a.data.start_cost;
      const roiB = (b.data.avg_yield_lb * b.data.avg_price_lb) / b.data.start_cost;
      return roiB - roiA;
    })
    .slice(0, 20)
    .map((p) => p.id)
);

const isTop20 = top20Ids.has(plant.id);

const faqJsonLd = isTop20
  ? {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": `How long does ${name} take to grow?`,
          "acceptedAnswer": {
            "@type": "Answer",
            "text": `From seed to harvest, ${name} takes ${days_min}–${days_max} days.`,
          },
        },
        {
          "@type": "Question",
          "name": `How much does ${name} yield per plant?`,
          "acceptedAnswer": {
            "@type": "Answer",
            "text": `${name} produces an average of ${avg_yield_lb} lbs per plant or per season.`,
          },
        },
        ...(companion_plants.length > 0
          ? [
              {
                "@type": "Question",
                "name": `What are good companion plants for ${name}?`,
                "acceptedAnswer": {
                  "@type": "Answer",
                  "text": `Good companion plants for ${name} include ${companion_plants.join(', ')}.`,
                },
              },
            ]
          : []),
      ],
    }
  : null;

const cropDescription = plant.data.description ?? `Complete care guide for ${name} (${scientific_name})  -  growing tips, ROI breakdown, watering, sunlight, and companion plants.`;
const cropImage = plant.data.hero_image
  ? new URL(plant.data.hero_image, Astro.site).toString()
  : new URL('/logo.png', Astro.site).toString();

const articleJsonLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": `${name}: ROI, Yield & Growing Guide`,
  "description": cropDescription,
  "image": cropImage,
  "publisher": {
    "@type": "Organization",
    "name": "Garden ROI",
    "logo": { "@type": "ImageObject", "url": new URL('/logo.png', Astro.site).toString() },
  },
};
---

<ContentLayout
  title={`${name}: ROI, Yield & Growing Guide`}
  description={cropDescription}
  ogImage={plant.data.hero_image}
  breadcrumbs={[{ label: 'Crops', href: '/crops/' }]}
  pageJsonLd={articleJsonLd}
>
  {faqJsonLd && (
    <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />
  )}
  <div class="plant-detail" data-pagefind-body>
    <!-- Header -->
    <div class="plant-header">
      <span class={tagClass}>{category}</span>
      <h1 class="plant-title">{name}</h1>
      <p class="plant-scientific">{scientific_name}</p>
    </div>

    {plant.data.hero_image && (
      <img
        src={plant.data.hero_image}
        alt={`${name} growing in a garden`}
        class="plant-hero"
        width="800"
        height="450"
        loading="eager"
      />
    )}

    <!-- Stats grid -->
    <div class="stats-grid">
      <div class="stat-card">
        <span class="stat-value">{days_min}–{days_max}</span>
        <span class="stat-label">Days to Harvest</span>
      </div>
      <div class="stat-card">
        <span class="stat-value">{avg_yield_lb} lb</span>
        <span class="stat-label">Avg Yield</span>
      </div>
      <div class="stat-card">
        <span class="stat-value">${avg_price_lb}/lb</span>
        <span class="stat-label">Grocery Value</span>
      </div>
      <div class="stat-card stat-card-highlight">
        <span class="stat-value">${roiEstimate}</span>
        <span class="stat-label">Est. Harvest Value</span>
      </div>
    </div>

    <!-- Quick facts -->
    <div class="quick-facts">
      <div class="fact">
        <span class="fact-label">💧 Watering</span>
        <span class="fact-value">{watering}</span>
      </div>
      <div class="fact">
        <span class="fact-label">☀️ Sunlight</span>
        <span class="fact-value">{sunlight}</span>
      </div>
      {companion_plants.length > 0 && (
        <div class="fact">
          <span class="fact-label">🌿 Companions</span>
          <span class="fact-value">
            {companion_plants.map((cp, i) => {
              const slug = nameToSlug(cp);
              return (
                <>
                  {plantSlugs.has(slug)
                    ? <a href={`/crops/${slug}/`}>{cp}</a>
                    : <span>{cp}</span>
                  }
                  {i < companion_plants.length - 1 ? ', ' : ''}
                </>
              );
            })}
          </span>
        </div>
      )}
    </div>

    <!-- Article body -->
    <div class="prose plant-body">
      <Content />
    </div>

    <!-- Related Articles (M003) -->
    {relatedArticles.length > 0 && (
      <div class="related-articles">
        <h2 class="related-title">Related Reading</h2>
        <div class="related-list">
          {relatedArticles.map((article) => (
            <a href={`${sectionPath(article.data.category)}/${article.id}/`} class="related-entry">
              <span class="related-article-title">{article.data.title}</span>
              <span class="related-article-desc">{article.data.description}</span>
            </a>
          ))}
        </div>
      </div>
    )}

    <!-- Related Crops -->
    {relatedCrops.length > 0 && (
      <div class="related-crops">
        <h2 class="related-title">Related Crops</h2>
        <div class="related-crops-grid">
          {relatedCrops.map((p) => (
            <PlantCard
              slug={p.id}
              name={p.data.name}
              scientific_name={p.data.scientific_name}
              category={p.data.category}
              days_min={p.data.days_min}
              days_max={p.data.days_max}
              avg_yield_lb={p.data.avg_yield_lb}
              avg_price_lb={p.data.avg_price_lb}
              watering={p.data.watering}
              sunlight={p.data.sunlight}
            />
          ))}
        </div>
      </div>
    )}

    <!-- Track CTA -->
    <div class="track-cta">
      <p>Growing {name}? Track your harvest value and break-even date in the Garden ROI app.</p>
      <a href="/#download" class="btn btn-primary">Get the App</a>
    </div>
  </div>
</ContentLayout>

<style>
  .plant-detail {
    display: flex;
    flex-direction: column;
    gap: var(--space-xl);
  }

  .plant-header {
    display: flex;
    flex-direction: column;
    gap: var(--space-s);
    padding-bottom: var(--space-l);
    border-bottom: 1px solid rgba(0,0,0,0.08);
  }

  .plant-hero {
    width: 100%;
    max-height: 360px;
    object-fit: cover;
    border-radius: var(--radius-m);
    display: block;
  }

  .plant-title {
    font-family: var(--font-display);
    font-size: var(--text-screen-title);
    line-height: var(--leading-screen-title);
    color: var(--color-primary);
    margin: 0;
  }

  .plant-scientific {
    font-size: var(--text-body);
    color: var(--color-text-muted);
    font-style: italic;
    margin: 0;
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-m);
  }

  .stat-card {
    background-color: var(--color-bg);
    border-radius: var(--radius-m);
    padding: var(--space-m);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-xs);
    text-align: center;
  }

  .stat-card-highlight {
    background-color: var(--color-highlight);
    border: 1px solid rgba(45, 90, 39, 0.15);
  }

  .stat-value {
    font-size: var(--text-h2);
    font-weight: 700;
    color: var(--color-primary);
    line-height: 1.2;
  }

  .stat-label {
    font-size: var(--text-small);
    color: var(--color-text-muted);
    line-height: 1.3;
  }

  .quick-facts {
    display: flex;
    flex-direction: column;
    gap: var(--space-s);
    background-color: var(--color-white);
    border-radius: var(--radius-m);
    padding: var(--space-l);
    border: 1px solid rgba(0,0,0,0.06);
  }

  .fact {
    display: flex;
    gap: var(--space-m);
    align-items: baseline;
  }

  .fact-label {
    font-size: var(--text-small);
    font-weight: 600;
    color: var(--color-text-secondary);
    min-width: 140px;
  }

  .fact-value {
    font-size: var(--text-small);
    color: var(--color-text-muted);
  }

  .plant-body {
    padding-top: var(--space-m);
  }

  .related-articles {
    display: flex;
    flex-direction: column;
    gap: var(--space-m);
  }

  .related-title {
    font-size: var(--text-h3);
    font-weight: 700;
    color: var(--color-text-primary);
    margin: 0;
  }

  .related-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-s);
  }

  .related-crops {
    display: flex;
    flex-direction: column;
    gap: var(--space-m);
  }

  .related-crops-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: var(--space-m);
  }

  .related-entry {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
    padding: var(--space-m) var(--space-l);
    background-color: var(--color-white);
    border-radius: var(--radius-m);
    border: 1px solid rgba(0, 0, 0, 0.06);
    text-decoration: none;
    transition: border-color 0.15s, box-shadow 0.15s;
  }

  .related-entry:hover {
    border-color: var(--color-primary);
    box-shadow: var(--shadow-soft);
  }

  .related-article-title {
    font-weight: 700;
    font-size: var(--text-body);
    color: var(--color-primary);
  }

  .related-article-desc {
    font-size: var(--text-small);
    color: var(--color-text-secondary);
    line-height: var(--leading-small);
  }

  .track-cta {
    background: linear-gradient(135deg, var(--color-primary-dark), var(--color-primary));
    border-radius: var(--radius-m);
    padding: var(--space-xl);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-l);
    flex-wrap: wrap;
  }

  .track-cta p {
    color: rgba(255,255,255,0.9);
    font-size: var(--text-body);
    margin: 0;
    max-width: 500px;
  }

  @media (max-width: 700px) {
    .stats-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 480px) {
    .stats-grid {
      grid-template-columns: 1fr 1fr;
    }

    .fact {
      flex-direction: column;
      gap: var(--space-xs);
    }
  }
</style>
