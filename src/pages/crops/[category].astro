---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PlantCard from '../../components/PlantCard.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  return [
    {
      params: { category: 'vegetables' },
      props: {
        collectionCategory: 'Vegetable',
        title: 'Vegetables: Best ROI Crops for the Home Garden',
        description: 'High-yield vegetables ranked by return on investment. Yield data, seed costs, and grocery value per plant  -  so you grow what actually pays off.',
        heading: 'Vegetables',
        subheading: 'High-yield vegetables ranked by harvest value and ROI.',
      },
    },
    {
      params: { category: 'herbs' },
      props: {
        collectionCategory: 'Herb',
        title: 'Herbs: High-Value Crops for Any Garden Size',
        description: 'Fresh herbs return more value per square foot than almost any vegetable. Yield data, seed costs, and grocery price comparisons for the best culinary herbs.',
        heading: 'Herbs',
        subheading: 'Herbs return more value per square foot than almost any vegetable.',
      },
    },
    {
      params: { category: 'fruit' },
      props: {
        collectionCategory: 'Fruit',
        title: 'Fruit: Perennial ROI and Long-Term Garden Value',
        description: 'Fruit crops pay off over years, not seasons. Yield data, establishment costs, and long-term ROI for strawberries, berries, and tree fruit.',
        heading: 'Fruit',
        subheading: 'Fruit crops compound in value over years  -  the math on establishment cost vs. lifetime yield.',
      },
    },
  ];
}

const { category } = Astro.params;
const { collectionCategory, title, description, heading, subheading } = Astro.props;

const allPlants = await getCollection('plants');
const plants = allPlants
  .filter((p) => p.data.category === collectionCategory)
  .sort((a, b) => {
    const roiA = (a.data.avg_yield_lb * a.data.avg_price_lb) / a.data.start_cost;
    const roiB = (b.data.avg_yield_lb * b.data.avg_price_lb) / b.data.start_cost;
    return roiB - roiA;
  });
---

<BaseLayout title={title} description={description}>
  <div class="page-header">
    <div class="container">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <ol>
          <li><a href="/">Home</a></li>
          <li><a href="/crops/">Crops</a></li>
          <li aria-current="page">{heading}</li>
        </ol>
      </nav>
      <h1>{heading}</h1>
      <p>{subheading}</p>
    </div>
  </div>

  <div class="container category-page">
    <div class="glass-card controls-card">
      <div class="search-bar">
        <input
          type="search"
          id="crop-search"
          class="crop-search-input"
          placeholder="Search crops..."
          aria-label="Search crops"
          autocomplete="off"
        />
      </div>

      <!-- Mobile dropdown (hidden on desktop) -->
      <div class="mobile-controls">
        <select id="mobile-filter" class="mobile-select" aria-label="Filter by category">
          <option value="all">All Crops</option>
          <option value="vegetables" selected={category === 'vegetables'}>Vegetables</option>
          <option value="herbs" selected={category === 'herbs'}>Herbs</option>
          <option value="fruit" selected={category === 'fruit'}>Fruit</option>
        </select>
      </div>

      <!-- Desktop category nav (hidden on mobile) -->
      <div class="category-nav">
        <a href="/crops/" class="cat-link">All Crops</a>
        <a href="/crops/vegetables/" class={`cat-link${category === 'vegetables' ? ' active' : ''}`}>Vegetables</a>
        <a href="/crops/herbs/" class={`cat-link${category === 'herbs' ? ' active' : ''}`}>Herbs</a>
        <a href="/crops/fruit/" class={`cat-link${category === 'fruit' ? ' active' : ''}`}>Fruit</a>
      </div>
    </div>

    {plants.length === 0 ? (
      <p class="empty">No crops in this category yet. Check back soon.</p>
    ) : (
      <div class="plants-grid" id="plants-grid">
        {plants.map((plant) => (
          <div class="plant-card-wrapper" data-name={plant.data.name.toLowerCase()}>
            <PlantCard
              slug={plant.id}
              name={plant.data.name}
              scientific_name={plant.data.scientific_name}
              category={plant.data.category}
              days_min={plant.data.days_min}
              days_max={plant.data.days_max}
              avg_yield_lb={plant.data.avg_yield_lb}
              avg_price_lb={plant.data.avg_price_lb}
              watering={plant.data.watering}
              sunlight={plant.data.sunlight}
            />
          </div>
        ))}
      </div>
    )}
  </div>
</BaseLayout>

<script>
  const searchInput = document.getElementById('crop-search') as HTMLInputElement | null;
  searchInput?.addEventListener('input', () => {
    const q = searchInput.value.toLowerCase().trim();
    document.querySelectorAll<HTMLElement>('.plant-card-wrapper').forEach(el => {
      el.style.display = (!q || (el.dataset.name ?? '').includes(q)) ? '' : 'none';
    });
  });

  const mobileFilter = document.getElementById('mobile-filter') as HTMLSelectElement | null;
  mobileFilter?.addEventListener('change', () => {
    const val = mobileFilter.value;
    if (val === 'all')        window.location.href = '/crops/';
    if (val === 'vegetables') window.location.href = '/crops/vegetables/';
    if (val === 'herbs')      window.location.href = '/crops/herbs/';
    if (val === 'fruit')      window.location.href = '/crops/fruit/';
  });
</script>

<style>
  .breadcrumb ol {
    display: flex;
    gap: var(--space-xs);
    list-style: none;
    padding: 0;
    margin: 0 0 var(--space-m);
    font-size: var(--text-small);
  }

  .breadcrumb li {
    display: flex;
    align-items: center;
    gap: var(--space-xs);
    color: rgba(255, 255, 255, 0.7);
  }

  .breadcrumb li:not(:last-child)::after {
    content: '/';
    color: rgba(255, 255, 255, 0.4);
  }

  .breadcrumb a {
    color: rgba(255, 255, 255, 0.85);
    text-decoration: none;
  }

  .breadcrumb a:hover {
    color: var(--color-white);
    text-decoration: underline;
  }

  .category-page {
    padding: var(--space-xl) var(--space-l);
  }

  /* Controls card — extends .glass-card from theme.css */
  .controls-card {
    padding: var(--space-l);
    margin-bottom: var(--space-xl);
    display: flex;
    flex-direction: column;
    gap: var(--space-m);
  }

  .crop-search-input {
    width: 100%;
    max-width: 420px;
    padding: var(--space-s) var(--space-m);
    border: 2px solid var(--color-primary);
    border-radius: var(--radius-full);
    font-size: var(--text-body);
    font-family: var(--font-body);
    color: var(--color-text-primary);
    background-color: var(--color-white);
    outline: none;
  }

  .crop-search-input:focus {
    border-color: var(--color-primary-dark);
    box-shadow: 0 0 0 3px rgba(45, 90, 39, 0.15);
  }

  .category-nav {
    display: flex;
    gap: var(--space-s);
    flex-wrap: wrap;
  }

  .cat-link {
    padding: var(--space-xs) var(--space-m);
    border-radius: var(--radius-full);
    border: 2px solid var(--color-primary);
    color: var(--color-primary);
    font-size: var(--text-small);
    font-weight: 600;
    text-decoration: none;
    transition: background-color 0.2s, color 0.2s;
    background: transparent;
  }

  .cat-link:hover,
  .cat-link.active {
    background-color: var(--color-primary);
    color: var(--color-white);
    text-decoration: none;
  }

  /* Mobile dropdown */
  .mobile-controls {
    display: none;
  }

  .mobile-select {
    width: 100%;
    padding: var(--space-s) var(--space-m);
    border: 2px solid var(--color-primary);
    border-radius: var(--radius-full);
    font-family: var(--font-body);
    font-size: var(--text-small);
    font-weight: 600;
    color: var(--color-primary);
    background-color: var(--color-white);
    outline: none;
    cursor: pointer;
  }

  @media (max-width: 680px) {
    .mobile-controls {
      display: block;
    }

    .category-nav {
      display: none;
    }
  }

  .plants-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-l);
  }

  .plant-card-wrapper {
    display: contents;
  }

  .empty {
    color: var(--color-text-muted);
    font-size: var(--text-body);
    padding: var(--space-xl) 0;
  }

  @media (max-width: 900px) {
    .plants-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 600px) {
    .plants-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
