---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PlantCard from '../../components/PlantCard.astro';
import { getCollection } from 'astro:content';

const allPlants = await getCollection('plants');

// Sort by ROI score descending: (yield × price) / seed_cost
const plants = [...allPlants].sort((a, b) => {
  const roiA = (a.data.avg_yield_lb * a.data.avg_price_lb) / a.data.seed_cost;
  const roiB = (b.data.avg_yield_lb * b.data.avg_price_lb) / b.data.seed_cost;
  return roiB - roiA;
});

const collectionJsonLd = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "Garden Crop Encyclopedia - ROI & Growing Guides",
  "description": "Vegetables, herbs, and fruit ranked by return on investment. Yield data, seed costs, and grocery value for home garden crops.",
  "url": "https://gardenroi.com/crops/",
  "publisher": {
    "@type": "Organization",
    "name": "Garden ROI",
    "logo": "https://gardenroi.com/logo.png"
  },
  "hasPart": plants.map((plant) => ({
    "@type": "Article",
    "name": `${plant.data.name}: ROI, Yield & Growing Guide`,
    "url": `https://gardenroi.com/crops/${plant.id}/`,
  })),
};
---

<BaseLayout
  title="High-ROI Crops for the Home Garden"
  description="Vegetables, herbs, and fruit ranked by return on investment. Yield data, seed costs, and grocery value so you grow what actually pays off."
>
  <script type="application/ld+json" set:html={JSON.stringify(collectionJsonLd)} />
  <div class="page-header">
    <div class="container">
      <h1>Crops</h1>
      <p>All crops ranked by ROI  -  harvest value divided by seed cost.</p>
    </div>
  </div>

  <div class="container plants-page">
    <div class="controls-card">
      <div class="search-bar">
        <input
          type="search"
          id="crop-search"
          class="crop-search-input"
          placeholder="Search crops..."
          aria-label="Search crops"
          autocomplete="off"
        />
      </div>

      <div class="controls-row">
        <div class="sort-bar" role="toolbar" aria-label="Sort crops">
          <span class="sort-label">Sort by:</span>
          <button class="sort-btn active" id="sort-roi" data-sort="roi" type="button" aria-pressed="true">Best ROI</button>
          <button class="sort-btn" id="sort-days" data-sort="days" type="button" aria-pressed="false">Fastest Harvest</button>
          <button class="sort-btn" id="sort-price" data-sort="price" type="button" aria-pressed="false">Highest Price/lb</button>
        </div>

        <div class="filter-bar" role="group" aria-label="Filter by category">
          <span class="sort-label">Category:</span>
          <a href="/crops/" class="filter-btn active">All</a>
          <a href="/crops/vegetables/" class="filter-btn">Vegetables</a>
          <a href="/crops/herbs/" class="filter-btn">Herbs</a>
          <a href="/crops/fruit/" class="filter-btn">Fruit</a>
          <span class="filter-separator" aria-hidden="true"></span>
          <button class="filter-btn qw-btn" id="quick-wins-btn" type="button" aria-pressed="false">Quick Wins (&le;60 days)</button>
        </div>

        <div class="view-toggle" role="group" aria-label="View mode">
          <button class="view-btn active" id="view-grid" data-view="grid" type="button" aria-label="Grid view" title="Grid view">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
              <rect x="1" y="1" width="6" height="6" rx="1"/>
              <rect x="9" y="1" width="6" height="6" rx="1"/>
              <rect x="1" y="9" width="6" height="6" rx="1"/>
              <rect x="9" y="9" width="6" height="6" rx="1"/>
            </svg>
          </button>
          <button class="view-btn" id="view-table" data-view="table" type="button" aria-label="Table view" title="Table view">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true">
              <rect x="1" y="1" width="14" height="14" rx="1.5"/>
              <line x1="1" y1="5.5" x2="15" y2="5.5"/>
              <line x1="5.5" y1="5.5" x2="5.5" y2="15"/>
            </svg>
          </button>
        </div>
      </div>
    </div>

    <!-- Card grid view -->
    <div class="plants-grid" id="plants-grid">
      {plants.map((plant) => {
        const roi = (plant.data.avg_yield_lb * plant.data.avg_price_lb) / plant.data.seed_cost;
        const estRoi = (plant.data.avg_yield_lb * plant.data.avg_price_lb - plant.data.seed_cost).toFixed(2);
        return (
          <div
            class="plant-card-wrapper"
            data-roi={roi.toFixed(4)}
            data-days={plant.data.days_min}
            data-days-max={plant.data.days_max}
            data-price={plant.data.avg_price_lb}
            data-slug={plant.id}
            data-est-roi={estRoi}
            data-yield={plant.data.avg_yield_lb}
            data-seed={plant.data.seed_cost}
            data-name={plant.data.name.toLowerCase()}
          >
            <PlantCard
              slug={plant.id}
              name={plant.data.name}
              scientific_name={plant.data.scientific_name}
              category={plant.data.category}
              days_min={plant.data.days_min}
              days_max={plant.data.days_max}
              avg_yield_lb={plant.data.avg_yield_lb}
              avg_price_lb={plant.data.avg_price_lb}
              watering={plant.data.watering}
              sunlight={plant.data.sunlight}
            />
          </div>
        );
      })}
    </div>

    <!-- Table view -->
    <div class="plants-table-wrap" id="plants-table-wrap" aria-hidden="true">
      <table class="plants-table" id="plants-table">
        <thead>
          <tr>
            <th class="th-sort" data-col="name">Crop <span class="th-arrow"></span></th>
            <th class="th-sort" data-col="days">Days <span class="th-arrow"></span></th>
            <th class="th-sort" data-col="yield">Yield (lb) <span class="th-arrow"></span></th>
            <th class="th-sort" data-col="price">Price ($/lb) <span class="th-arrow"></span></th>
            <th class="th-sort" data-col="seed">Seed ($) <span class="th-arrow"></span></th>
            <th class="th-sort th-sort-active" data-col="roi" aria-sort="descending">Est. ROI <span class="th-arrow">▼</span></th>
          </tr>
        </thead>
        <tbody id="plants-tbody">
          {plants.map((plant) => {
            const roi = (plant.data.avg_yield_lb * plant.data.avg_price_lb) / plant.data.seed_cost;
            const estRoi = (plant.data.avg_yield_lb * plant.data.avg_price_lb - plant.data.seed_cost).toFixed(2);
            const catClass = `tag tag-${plant.data.category.toLowerCase()}`;
            return (
              <tr
                class="table-row"
                data-roi={roi.toFixed(4)}
                data-days={plant.data.days_min}
                data-price={plant.data.avg_price_lb}
                data-yield={plant.data.avg_yield_lb}
                data-seed={plant.data.seed_cost}
                data-est-roi={estRoi}
                data-days-max={plant.data.days_max}
                data-name={plant.data.name.toLowerCase()}
                data-slug={plant.id}
              >
                <td class="td-name">
                  <a href={`/crops/${plant.id}/`} class="td-name-link">{plant.data.name}</a>
                  <span class={catClass}>{plant.data.category}</span>
                </td>
                <td>{plant.data.days_min}–{plant.data.days_max}</td>
                <td>{plant.data.avg_yield_lb}</td>
                <td>${plant.data.avg_price_lb.toFixed(2)}</td>
                <td>${plant.data.seed_cost.toFixed(2)}</td>
                <td class="td-roi-val">${estRoi}</td>
              </tr>
            );
          })}
        </tbody>
      </table>
    </div>
  </div>
</BaseLayout>

<script>
  const STORAGE_KEY = 'crops-view';

  // --- View toggle ---
  function setView(view: string) {
    const grid = document.getElementById('plants-grid');
    const tableWrap = document.getElementById('plants-table-wrap');

    if (view === 'table') {
      grid?.classList.add('view-hidden');
      tableWrap?.classList.remove('view-hidden');
      tableWrap?.setAttribute('aria-hidden', 'false');
    } else {
      grid?.classList.remove('view-hidden');
      tableWrap?.classList.add('view-hidden');
      tableWrap?.setAttribute('aria-hidden', 'true');
    }

    document.querySelectorAll<HTMLButtonElement>('.view-btn').forEach(b => {
      b.classList.toggle('active', b.dataset.view === view);
    });

    try { localStorage.setItem(STORAGE_KEY, view); } catch (_) {}
  }

  // Apply stored preference on load (desktop only)
  try {
    const saved = localStorage.getItem(STORAGE_KEY);
    if (saved === 'table' && window.innerWidth > 640) setView('table');
  } catch (_) {}

  document.querySelectorAll<HTMLButtonElement>('.view-btn').forEach(btn => {
    btn.addEventListener('click', () => setView(btn.dataset.view ?? 'grid'));
  });

  // --- Search + Quick Wins filter (both views) ---
  let quickWinsActive = false;

  function applyFilters(query: string) {
    const q = query.toLowerCase().trim();
    document.querySelectorAll<HTMLElement>('.plant-card-wrapper').forEach(el => {
      const matchSearch = !q || (el.textContent?.toLowerCase() ?? '').includes(q);
      const daysMax = parseInt(el.dataset.daysMax ?? '999', 10);
      const matchQW = !quickWinsActive || daysMax <= 60;
      el.style.display = (matchSearch && matchQW) ? '' : 'none';
    });
    document.querySelectorAll<HTMLElement>('.table-row').forEach(el => {
      const matchSearch = !q || (el.textContent?.toLowerCase() ?? '').includes(q);
      const daysMax = parseInt(el.dataset.daysMax ?? '999', 10);
      const matchQW = !quickWinsActive || daysMax <= 60;
      el.style.display = (matchSearch && matchQW) ? '' : 'none';
    });
  }

  // Make entire table rows clickable
  document.querySelectorAll<HTMLElement>('.table-row').forEach(row => {
    row.addEventListener('click', (e) => {
      if ((e.target as HTMLElement).closest('a')) return;
      const slug = row.dataset.slug;
      if (slug) window.location.href = `/crops/${slug}/`;
    });
  });

  const searchInput = document.getElementById('crop-search') as HTMLInputElement | null;
  if (searchInput) {
    searchInput.addEventListener('input', () => applyFilters(searchInput.value));
  }

  const qwBtn = document.getElementById('quick-wins-btn') as HTMLButtonElement | null;
  qwBtn?.addEventListener('click', () => {
    quickWinsActive = !quickWinsActive;
    qwBtn.classList.toggle('active', quickWinsActive);
    qwBtn.setAttribute('aria-pressed', String(quickWinsActive));
    applyFilters(searchInput?.value ?? '');
  });

  // --- Sort helpers ---
  function sortCardWrappers(sortBy: string) {
    const grid = document.getElementById('plants-grid');
    if (!grid) return;
    const wrappers = Array.from(grid.querySelectorAll<HTMLElement>('.plant-card-wrapper'));
    wrappers.sort((a, b) => {
      if (sortBy === 'roi')   return parseFloat(b.dataset.roi ?? '0') - parseFloat(a.dataset.roi ?? '0');
      if (sortBy === 'days')  return parseInt(a.dataset.days ?? '0', 10) - parseInt(b.dataset.days ?? '0', 10);
      if (sortBy === 'price') return parseFloat(b.dataset.price ?? '0') - parseFloat(a.dataset.price ?? '0');
      return 0;
    });
    wrappers.forEach(el => grid.appendChild(el));
  }

  function sortTableRows(col: string, dir: 'asc' | 'desc') {
    const tbody = document.getElementById('plants-tbody');
    if (!tbody) return;
    const rows = Array.from(tbody.querySelectorAll<HTMLElement>('.table-row'));
    rows.sort((a, b) => {
      if (col === 'name') {
        const as = a.dataset.name ?? '', bs = b.dataset.name ?? '';
        return dir === 'asc' ? as.localeCompare(bs) : bs.localeCompare(as);
      }
      let av = 0, bv = 0;
      switch (col) {
        case 'days':  av = parseInt(a.dataset.days ?? '0', 10);  bv = parseInt(b.dataset.days ?? '0', 10);  break;
        case 'yield': av = parseFloat(a.dataset.yield ?? '0');   bv = parseFloat(b.dataset.yield ?? '0');   break;
        case 'price': av = parseFloat(a.dataset.price ?? '0');   bv = parseFloat(b.dataset.price ?? '0');   break;
        case 'seed':  av = parseFloat(a.dataset.seed ?? '0');    bv = parseFloat(b.dataset.seed ?? '0');    break;
        case 'roi':   av = parseFloat(a.dataset.estRoi ?? '0');  bv = parseFloat(b.dataset.estRoi ?? '0'); break;
      }
      return dir === 'asc' ? av - bv : bv - av;
    });
    rows.forEach(el => tbody.appendChild(el));
  }

  function updateThHeaders(activeCol: string, dir: 'asc' | 'desc') {
    document.querySelectorAll<HTMLElement>('.th-sort').forEach(th => {
      const isActive = th.dataset.col === activeCol;
      th.classList.toggle('th-sort-active', isActive);
      const arrow = th.querySelector('.th-arrow');
      if (arrow) arrow.textContent = isActive ? (dir === 'asc' ? '▲' : '▼') : '';
      th.setAttribute('aria-sort', isActive ? (dir === 'asc' ? 'ascending' : 'descending') : 'none');
    });
  }

  // --- Sort bar buttons (sync both views) ---
  document.querySelectorAll<HTMLButtonElement>('.sort-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll<HTMLButtonElement>('.sort-btn').forEach(b => {
        b.classList.remove('active');
        b.setAttribute('aria-pressed', 'false');
      });
      btn.classList.add('active');
      btn.setAttribute('aria-pressed', 'true');
      const sortBy = btn.dataset.sort ?? 'roi';
      sortCardWrappers(sortBy);
      // Sync table: map sort bar keys to table cols
      const colMap: Record<string, string> = { roi: 'roi', days: 'days', price: 'price' };
      const dir = sortBy === 'days' ? 'asc' : 'desc';
      const col = colMap[sortBy] ?? 'roi';
      sortTableRows(col, dir);
      updateThHeaders(col, dir);
    });
  });

  // --- Table column header sort ---
  let tableSort = { col: 'roi', dir: 'desc' as 'asc' | 'desc' };

  document.querySelectorAll<HTMLElement>('.th-sort').forEach(th => {
    th.addEventListener('click', () => {
      const col = th.dataset.col ?? 'roi';
      if (tableSort.col === col) {
        tableSort.dir = tableSort.dir === 'asc' ? 'desc' : 'asc';
      } else {
        tableSort.col = col;
        tableSort.dir = col === 'name' ? 'asc' : 'desc';
      }
      sortTableRows(tableSort.col, tableSort.dir);
      updateThHeaders(tableSort.col, tableSort.dir);
      // Deactivate sort bar since table has its own sort now
      document.querySelectorAll<HTMLButtonElement>('.sort-btn').forEach(b => {
        b.classList.remove('active');
        b.setAttribute('aria-pressed', 'false');
      });
    });
  });
</script>

<style>
  .plants-page {
    padding: var(--space-xl) var(--space-l);
  }

  /* Controls card */
  .controls-card {
    background: rgba(248, 249, 245, 0.98);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-radius: var(--radius-l);
    border: 1px solid rgba(255, 255, 255, 0.7);
    padding: var(--space-l);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.18);
    margin-bottom: var(--space-xl);
    display: flex;
    flex-direction: column;
    gap: var(--space-m);
  }

  .search-bar {
    /* spacing handled by controls-card gap */
  }

  .crop-search-input {
    width: 100%;
    max-width: 420px;
    padding: var(--space-s) var(--space-m);
    border: 2px solid var(--color-primary);
    border-radius: var(--radius-full);
    font-size: var(--text-body);
    font-family: var(--font-body);
    color: var(--color-text-primary);
    background-color: var(--color-white);
    outline: none;
  }

  .crop-search-input:focus {
    border-color: var(--color-primary-dark);
    box-shadow: 0 0 0 3px rgba(45, 90, 39, 0.15);
  }

  .controls-row {
    display: flex;
    align-items: center;
    gap: var(--space-l);
    flex-wrap: wrap;
  }

  .controls-row .sort-bar {
    flex: 1;
  }

  .controls-row .filter-bar {
    flex-shrink: 0;
  }

  .sort-bar {
    display: flex;
    align-items: center;
    gap: var(--space-s);
    flex-wrap: wrap;
  }

  .sort-label {
    font-size: var(--text-small);
    font-weight: 600;
    color: var(--color-text-muted);
  }

  .sort-btn {
    padding: var(--space-xs) var(--space-m);
    border-radius: var(--radius-full);
    border: 2px solid var(--color-primary);
    color: var(--color-primary);
    font-size: var(--text-small);
    font-weight: 600;
    background: transparent;
    cursor: pointer;
    font-family: var(--font-body);
    transition: background-color 0.2s, color 0.2s;
  }

  .sort-btn:hover,
  .sort-btn.active {
    background-color: var(--color-primary);
    color: var(--color-white);
  }

  .filter-bar {
    display: flex;
    align-items: center;
    gap: var(--space-s);
    flex-wrap: wrap;
  }

  .filter-btn {
    padding: var(--space-xs) var(--space-m);
    border-radius: var(--radius-full);
    border: 2px solid var(--color-primary);
    color: var(--color-primary);
    font-size: var(--text-small);
    font-weight: 600;
    text-decoration: none;
    transition: background-color 0.2s, color 0.2s;
    background: transparent;
  }

  .filter-btn:hover,
  .filter-btn.active {
    background-color: var(--color-primary);
    color: var(--color-white);
    text-decoration: none;
  }

  button.filter-btn {
    cursor: pointer;
    font-family: var(--font-body);
  }

  .filter-separator {
    display: inline-block;
    width: 1px;
    height: 20px;
    background-color: var(--color-border);
    align-self: center;
    margin: 0 var(--space-xs);
  }

  /* View toggle */
  .view-toggle {
    display: flex;
    gap: var(--space-xs);
    flex-shrink: 0;
    margin-left: auto;
  }

  .view-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border: 2px solid var(--color-primary);
    border-radius: var(--radius-s);
    background: transparent;
    color: var(--color-primary);
    cursor: pointer;
    transition: background-color 0.2s, color 0.2s;
    padding: 0;
  }

  .view-btn:hover,
  .view-btn.active {
    background-color: var(--color-primary);
    color: var(--color-white);
  }

  /* Hide/show utility */
  .view-hidden {
    display: none !important;
  }

  /* Card grid */
  .plant-card-wrapper {
    display: contents;
  }

  .plants-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-l);
  }

  /* Table view */
  .plants-table-wrap {
    display: none;
    overflow-x: auto;
    border-radius: var(--radius-m);
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.10);
  }

  /* Override display:none when not hidden */
  .plants-table-wrap:not(.view-hidden) {
    display: block;
  }

  .plants-table {
    width: 100%;
    border-collapse: collapse;
    font-size: var(--text-small);
    font-family: var(--font-body);
    background-color: var(--color-white);
  }

  .plants-table thead th {
    background-color: var(--color-primary);
    color: var(--color-white);
    padding: var(--space-s) var(--space-m);
    text-align: left;
    font-weight: 600;
    white-space: nowrap;
    font-size: var(--text-small);
  }

  .th-sort {
    cursor: pointer;
    user-select: none;
  }

  .th-sort:hover {
    background-color: var(--color-primary-dark);
  }

  .th-sort-active {
    background-color: var(--color-primary-dark);
  }

  .th-arrow {
    margin-left: var(--space-xs);
    font-size: var(--text-micro);
    display: inline-block;
    min-width: 1ch;
  }

  .plants-table tbody tr {
    border-bottom: 1px solid rgba(0, 0, 0, 0.06);
    transition: background-color 0.15s;
  }

  .table-row {
    cursor: pointer;
  }

  .plants-table tbody tr:nth-child(even) {
    background-color: var(--color-highlight);
  }

  .plants-table tbody tr:hover {
    background-color: rgba(45, 90, 39, 0.07);
  }

  .plants-table td {
    padding: var(--space-s) var(--space-m);
    color: var(--color-text-primary);
    vertical-align: middle;
    white-space: nowrap;
  }

  .td-name {
    display: flex;
    align-items: center;
    gap: var(--space-s);
    white-space: normal;
    min-width: 160px;
  }

  .td-name-link {
    font-weight: 600;
    color: var(--color-primary);
    text-decoration: none;
  }

  .td-name-link:hover {
    text-decoration: underline;
  }

  .td-roi-val {
    font-weight: 700;
    color: var(--color-primary);
  }

  /* Responsive */
  @media (max-width: 900px) {
    .plants-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 680px) {
    /* Controls: sort and filter stack vertically */
    .controls-row {
      flex-direction: column;
      align-items: stretch;
      gap: var(--space-m);
    }

    .controls-row .sort-bar,
    .controls-row .filter-bar {
      flex: unset;
      flex-shrink: unset;
    }

    .sort-bar,
    .filter-bar {
      gap: var(--space-xs);
    }

    .filter-separator {
      display: none;
    }
  }

  @media (max-width: 640px) {
    .plants-grid {
      grid-template-columns: 1fr;
    }
    .view-toggle {
      display: none;
    }
    .plants-table-wrap {
      display: none !important;
    }
  }
</style>
