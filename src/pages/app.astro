---
import BaseLayout from '../layouts/BaseLayout.astro';
import AppStoreBadges from '../components/AppStoreBadges.astro';

const breadcrumbJsonLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": String(Astro.site) },
    { "@type": "ListItem", "position": 2, "name": "App", "item": new URL('/app/', Astro.site).toString() },
  ],
};
---

<BaseLayout
  title="Garden ROI App — Track Harvests & Break-Even"
  description="The Garden ROI app tracks your harvests, expenses, and break-even date on iOS and Android. See which crops earn their space and grow smarter every season."
>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbJsonLd)} />

  <!-- Hero — same structure as homepage hero -->
  <section class="hero">
    <div class="hero-bg">
      <div class="hero-overlay"></div>
    </div>
    <div class="container hero-content">
      <div class="hero-text">
        <nav class="breadcrumb" aria-label="Breadcrumb">
          <ol>
            <li><a href="/">Home</a></li>
            <li aria-current="page">App</li>
          </ol>
        </nav>
        <h1>Your garden should pay&nbsp;you back.</h1>
        <p class="hero-lead">
          The Garden ROI app tracks every harvest, every expense, and tells you exactly when your garden breaks even — on iOS and Android.
        </p>
        <AppStoreBadges />
      </div>
      <div class="hero-icon">
        <img
          src="/logo.png"
          alt="Garden ROI app icon"
          width="160"
          height="160"
          loading="eager"
          class="app-icon"
        />
      </div>
    </div>
  </section>

  <!-- Page content -->
  <div class="container page-body">

    <!-- What the app does -->
    <section class="glass-card content-section">
      <h2 class="section-title">What the app does</h2>
      <div class="feature-grid">
        <div class="feature-card">
          <h3>Track every harvest</h3>
          <p>Log weight, date, and crop for every pick. The app builds your harvest record automatically.</p>
        </div>
        <div class="feature-card">
          <h3>See your break-even date</h3>
          <p>Enter your seed and supply costs once. The app updates your break-even date every time you log a harvest.</p>
        </div>
        <div class="feature-card">
          <h3>Know your best performers</h3>
          <p>Compare crops by total yield, value per square foot, and return on seed cost. Know what to plant more of next year.</p>
        </div>
        <div class="feature-card">
          <h3>800+ crop varieties</h3>
          <p>Pull from a library of over 800 USDA varieties — or add your own. Days to harvest, spacing, and grocery value all included.</p>
          <p class="feature-note">The app includes the full 800+ variety database. The <a href="/crops/">web crop library</a> features in-depth ROI guides for the highest-return crops.</p>
        </div>
      </div>
    </section>

    <!-- How site and app work together -->
    <section class="glass-card content-section">
      <div class="together-inner">
        <div class="together-text">
          <h2 class="section-title">How the site and app work together</h2>
          <p>This site answers the <em>how</em>: which crops are worth growing, when to plant them, how to make them last after harvest.</p>
          <p>The app answers the <em>whether</em>: is your garden actually paying off? What did your tomatoes return per pound compared to what you'd pay at the store? Is your break-even date getting closer or further away?</p>
          <p>Use the site to make smarter growing decisions. Use the app to see whether they're working.</p>
        </div>
        <div class="together-download">
          <p class="download-label">Free on iOS and Android</p>
          <AppStoreBadges />
        </div>
      </div>
    </section>

  </div>
</BaseLayout>

<style>
  /* Hero — mirrors homepage .hero exactly */
  .hero {
    position: relative;
    overflow: hidden;
    min-height: 480px;
    display: flex;
    align-items: center;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(0, 0, 0, 0.25) 0%,
      rgba(45, 90, 39, 0.55) 100%
    );
  }

  .hero-content {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1fr auto;
    gap: var(--space-xxl);
    align-items: center;
    padding-top: var(--space-xxl);
    padding-bottom: var(--space-xxl);
  }

  /* Breadcrumb inside hero */
  .breadcrumb ol {
    display: flex;
    gap: var(--space-xs);
    list-style: none;
    padding: 0;
    margin: 0 0 var(--space-m);
    font-size: var(--text-small);
  }

  .breadcrumb li {
    display: flex;
    align-items: center;
    gap: var(--space-xs);
    color: rgba(255, 255, 255, 0.7);
  }

  .breadcrumb li:not(:last-child)::after {
    content: '/';
    color: rgba(255, 255, 255, 0.4);
  }

  .breadcrumb a {
    color: rgba(255, 255, 255, 0.85);
    text-decoration: none;
  }

  .hero-text h1 {
    font-family: var(--font-display);
    font-size: clamp(36px, 5vw, var(--text-screen-title));
    line-height: 1.1;
    color: var(--color-tab-active);
    -webkit-text-stroke: 2px var(--color-tab-bar);
    paint-order: stroke fill;
    text-shadow: 0 3px 16px rgba(0, 0, 0, 0.4);
    margin: 0 0 var(--space-m);
  }

  .hero-lead {
    font-size: var(--text-body);
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.92);
    text-shadow: 0 1px 4px rgba(0, 0, 0, 0.2);
    margin: 0 0 var(--space-xl);
    max-width: 48ch;
  }

  .app-icon {
    border-radius: var(--radius-l);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
  }

  /* Page body */
  .page-body {
    padding: var(--space-xxl) var(--space-l);
    display: flex;
    flex-direction: column;
    gap: var(--space-xl);
  }

  .content-section {
    padding: var(--space-xl);
  }

  .section-title {
    font-family: var(--font-display);
    font-size: var(--text-h2);
    color: var(--color-primary);
    margin: 0 0 var(--space-xl);
  }

  /* Feature grid */
  .feature-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: var(--space-l);
  }

  .feature-card {
    background-color: var(--color-bg);
    border-radius: var(--radius-m);
    padding: var(--space-l);
    border: 1px solid rgba(0, 0, 0, 0.06);
  }

  .feature-card h3 {
    font-size: var(--text-h3);
    color: var(--color-primary);
    margin: 0 0 var(--space-s);
  }

  .feature-card p {
    font-size: var(--text-body);
    color: var(--color-text-secondary);
    line-height: 1.55;
    margin: 0;
  }

  .feature-note {
    font-size: var(--text-small);
    color: var(--color-text-muted);
    margin-top: var(--space-xs);
    border-top: 1px solid rgba(0, 0, 0, 0.06);
    padding-top: var(--space-xs);
  }

  /* Together section */
  .together-inner {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: var(--space-xxl);
    align-items: start;
  }

  .together-text p {
    color: var(--color-text-secondary);
    line-height: 1.65;
    margin: 0 0 var(--space-m);
    max-width: 60ch;
  }

  .together-text p:last-child {
    margin-bottom: 0;
  }

  .together-download {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-m);
    white-space: nowrap;
  }

  .download-label {
    font-size: var(--text-small);
    color: var(--color-text-muted);
    margin: 0;
  }

  /* Responsive */
  @media (max-width: 640px) {
    .hero-content {
      grid-template-columns: 1fr;
    }

    .hero-icon {
      display: none;
    }

    .together-inner {
      grid-template-columns: 1fr;
    }

    .together-download {
      align-items: flex-start;
      white-space: normal;
    }
  }

  @media (max-width: 900px) {
    .hero-text h1 {
      -webkit-text-stroke: 0.5px var(--color-tab-bar);
    }
  }
</style>
