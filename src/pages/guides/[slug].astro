---
import ArticleLayout from '../../layouts/ArticleLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const articles = await getCollection('articles');
  return articles
    .filter((a) => a.data.category === 'care' || a.data.category === 'planning')
    .map((article) => ({
      params: { slug: article.id },
      props: { article },
    }));
}

const { article } = Astro.props;
const categoryLabel = article.data.category === 'care' ? 'Plant Care' : 'Planning';
---

<ArticleLayout
  article={article}
  categoryTag={`tag-${article.data.category}`}
  categoryLabel={categoryLabel}
  backHref="/guides/"
  backLabel="← All Guides"
  primaryCtaHref="/crops/"
  primaryCtaLabel="Browse Crops"
  breadcrumbLabel="Guides"
  breadcrumbHref="/guides/"
/>
